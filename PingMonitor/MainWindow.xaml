<Window x:Class="PingMonitor.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        Title="Ping Monitor" Height="350" Width="525">
    <Grid>
        <Label Content="Ping Monitor" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0" />
        <StackPanel VerticalAlignment="Center">
            <TextBox Name="HostNameTextBox" Width="300" Height="25" Margin="10" PlaceholderText="Enter Hostname or IP" />
            <Button Name="PingButton" Width="100" Height="30" Margin="10" Content="Ping" Click="PingButton_Click" />
            <TextBlock Name="ResultTextBlock" FontSize="16" Margin="10" />
        </StackPanel>
    </Grid>
</Window>
