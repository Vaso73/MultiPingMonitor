<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        VisualStyle.Modern
        A cleaner, modern dark-dashboard aesthetic with softer corners,
        more generous spacing, and refined typography hierarchy.
        Designed to be CLEARLY VISUALLY DISTINCT from Classic at first glance.
    -->

    <!-- ── Layout tokens ─────────────────────────────────────────────── -->
    <CornerRadius x:Key="Style.CornerRadius">6</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Small">4</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Button">5</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Menu">6</CornerRadius>
    <Thickness x:Key="Style.Padding.Button">14,7</Thickness>
    <Thickness x:Key="Style.Padding.MenuItem">10,6,10,6</Thickness>
    <Thickness x:Key="Style.Padding.Header">16,12</Thickness>
    <Thickness x:Key="Style.BorderThickness">1</Thickness>
    <Thickness x:Key="Style.BorderThickness.Button">1</Thickness>
    <Thickness x:Key="Style.Margin.Section">4</Thickness>
    <System:Double x:Key="Style.FontSize.Normal"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>
    <System:Double x:Key="Style.FontSize.Header"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">18</System:Double>
    <System:Double x:Key="Style.FontSize.Menu"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>

    <!-- ── Opacity tokens ────────────────────────────────────────────── -->
    <System:Double x:Key="Style.Opacity.Secondary"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">0.82</System:Double>

    <!-- ── Window chrome ─────────────────────────────────────────────── -->
    <CornerRadius x:Key="Style.Window.CornerRadius">8</CornerRadius>

    <!-- ── Shared titlebar title style (all custom-chrome windows) ─── -->
    <Style x:Key="Style.TitleBar.Title" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         STYLE ROUTING – Modern versions with rounded corners,
         accent-tinted borders, softer hover effects, and refined spacing.
         ══════════════════════════════════════════════════════════════════ -->

    <!-- ── Modern Title Bar Button ─────────────────────────────────── -->
    <Style x:Key="Style.TitleBarButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="Transparent"
                            CornerRadius="4"
                            BorderThickness="0"
                            Margin="2,4"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Title Bar Close Button ───────────────────────────── -->
    <Style x:Key="Style.TitleBarCloseButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="Transparent"
                            CornerRadius="4"
                            BorderThickness="0"
                            Margin="2,4"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="#e81123" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background" Value="#f16f7a" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Pin / always-on-top toggle button (TargetType=ToggleButton) ── -->
    <Style x:Key="Style.PinToggleButton" TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="border"
                            Background="Transparent"
                            CornerRadius="4"
                            BorderThickness="0"
                            Margin="2,4"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Window Main Panel ────────────────────────────────── -->
    <Style x:Key="Style.WindowMainPanel" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource Style.Window.CornerRadius}" />
        <Setter Property="ClipToBounds" Value="True" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}" Value="Maximized">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ── Modern Header Panel (info bar below title bar) ──────────── -->
    <Style x:Key="Style.HeaderPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="Padding" Value="14,10,14,10" />
    </Style>

    <!-- ── Modern Live Ping Latency Badge ──────────────────────────── -->
    <Style x:Key="Style.LivePingLatencyBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <!-- ── Modern Live Ping Status Block ───────────────────────────── -->
    <Style x:Key="Style.LivePingStatusBlock" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ── Modern Live Ping Stat Segment (footer counter card) ─────── -->
    <Style x:Key="Style.LivePingStatSegment" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <!-- ── Modern Live Ping Log Row (left-accent indicator) ────────── -->
    <Style x:Key="Style.LivePingLogRow" TargetType="{x:Type Border}">
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="CornerRadius" Value="2,0,0,2" />
        <Setter Property="Padding" Value="8,2,6,2" />
        <Setter Property="Margin" Value="2,1,2,0" />
    </Style>

    <!-- ── Modern Live Ping Toolbar Separator ──────────────────────── -->
    <Style x:Key="Style.LivePingToolbarSeparator" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="8,2" />
        <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
    </Style>

    <!-- ── Modern Button (primary / dark) ──────────────────────────── -->
    <Style x:Key="Style.Button" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.AccentForeground}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="5"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="contentPresenter"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.75" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.40" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Standard Button (secondary – the most used button) ── -->
    <Style x:Key="Style.ButtonStandard" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="5"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="contentPresenter"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDefaulted" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.AccentHover}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.40" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Live Ping Footer Button ──────────────────────────── -->
    <Style x:Key="Style.LivePingFooterButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="5"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Live Ping Action Button (header buttons) ─────────── -->
    <Style x:Key="Style.LivePingActionButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="4"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Menu Popup Border ────────────────────────────────── -->
    <Style x:Key="Style.MenuPopupBorder" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,6" />
    </Style>

    <!-- ── Modern Content Panel (accent-bordered card surface) ─────── -->
    <Style x:Key="Style.ContentPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,16" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Margin" Value="6,8" />
    </Style>

    <!-- ── Modern Footer Panel ────────────────────────────────────── -->
    <Style x:Key="Style.FooterPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="0,2,0,0" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <!-- ── Modern Compact Row (card-like host row in Compact mode) ── -->
    <Style x:Key="Style.CompactRow" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="2,1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- ── Modern Compact Set Toolbar strip ────────────────────────── -->
    <Style x:Key="Style.CompactSetToolbar" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="0,1,0,1" />
        <Setter Property="Padding" Value="4,0" />
    </Style>

    <!-- ── Modern Compact Network Identity Footer ───────────────────── -->
    <!-- Same background weight as Style.CompactSetToolbar so it reads as a
         matching "header/footer" pair rather than a subtle debug bar. -->
    <Style x:Key="Style.CompactNetworkFooter" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="6,5" />
    </Style>

    <!-- ── Modern Compact Country Badge ─────────────────────────────── -->
    <Style x:Key="Style.CompactCountryBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Modern Compact Latency Badge ────────────────────────────── -->
    <Style x:Key="Style.CompactLatencyBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="Margin" Value="6,0,0,0" />
    </Style>

    <!-- ── Modern Probe Card spacing tokens ─────────────────────────── -->
    <Thickness x:Key="Style.ProbeCardAlias.Padding">6,7,4,7</Thickness>
    <Thickness x:Key="Style.ProbeCardGlyph.Padding">8,0,4,0</Thickness>
    <Thickness x:Key="Style.ProbeCardHostname.Padding">4,6,0,6</Thickness>
    <Thickness x:Key="Style.ProbeCardStatsLabel.Padding">6,3,0,3</Thickness>
    <Thickness x:Key="Style.ProbeCardStatsLabel.Margin">6,0,0,0</Thickness>

    <!-- ── Modern Probe Card grid / card corner radius tokens ─────────── -->
    <Thickness x:Key="Style.ProbeCardGrid.Margin">0</Thickness>
    <CornerRadius x:Key="Style.ProbeCardHeader.CornerRadius">6,6,0,0</CornerRadius>

    <!-- ── Modern Probe Card outer (rounded floating card) ─────────── -->
    <Style x:Key="Style.ProbeCard" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Margin" Value="3" />
    </Style>

    <!-- ── Modern Probe Card stats band (collapsible, tinted surface) ── -->
    <Style x:Key="Style.ProbeCardStats" TargetType="{x:Type DockPanel}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Path=Type}" Value="Ping">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=Statistics.Sent}" Value="0">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ── Modern Probe Card footer (rounded bottom to close the card) ── -->
    <Style x:Key="Style.ProbeCardFooter" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="CornerRadius" Value="0,0,6,6" />
    </Style>

    <!-- ── Modern Title-Bar Separator (accent line below menu bar) ──── -->
    <Style x:Key="Style.TitleBarSeparator" TargetType="{x:Type Border}">
        <Setter Property="Height" Value="2" />
        <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
    </Style>

    <!-- ── Modern Menu Sub-Popup Border (accent border, rounded) ────── -->
    <Style x:Key="Style.MenuSubPopupBorder" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <!-- ── Modern Menu Item hover tokens (accent-tinted per-style hover) ── -->
    <!--
         SolidColorBrush with DynamicResource Color: WPF resolves the Color DP at
         runtime through Freezable inheritance context once the brush is applied to a
         visual-tree element, making these live-track the active theme palette.
    -->
    <SolidColorBrush x:Key="Style.MenuItem.Hover.Background"   Color="{DynamicResource Theme.Accent.Color}"/>
    <SolidColorBrush x:Key="Style.MenuItem.Hover.BorderBrush"  Color="{DynamicResource Theme.Accent.Color}"/>
    <SolidColorBrush x:Key="Style.MenuItem.Hover.Foreground"   Color="{DynamicResource Theme.AccentForeground.Color}"/>

    <!-- ── Modern Header Toggle Button (e.g. Always-on-top in LPMW header) ── -->
    <Style x:Key="Style.HeaderToggleButton" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background"   Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="BorderBrush"  Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"      Value="5,2" />
        <Setter Property="FontSize"     Value="11" />
        <Setter Property="Cursor"       Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="ToggleBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Style.CornerRadius.Small}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ToggleBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="ToggleBorder" Property="BorderThickness" Value="2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Context Menu (rounded popup with accent border) ────── -->
    <Style x:Key="Style.ContextMenu" TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="3,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                        Grid.IsSharedSizeScope="True"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                        KeyboardNavigation.TabNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
