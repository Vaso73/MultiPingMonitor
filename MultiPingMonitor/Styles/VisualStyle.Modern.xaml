<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        VisualStyle.Modern
        A cleaner, modern dark-dashboard aesthetic with softer corners,
        more generous spacing, and refined typography hierarchy.
        Designed to be CLEARLY VISUALLY DISTINCT from Classic at first glance.
    -->

    <!-- ── Layout tokens ─────────────────────────────────────────────── -->
    <CornerRadius x:Key="Style.CornerRadius">6</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Small">4</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Button">5</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Menu">6</CornerRadius>
    <Thickness x:Key="Style.Padding.Button">14,7</Thickness>
    <Thickness x:Key="Style.Padding.MenuItem">10,6,10,6</Thickness>
    <Thickness x:Key="Style.Padding.Header">16,12</Thickness>
    <Thickness x:Key="Style.BorderThickness">1</Thickness>
    <Thickness x:Key="Style.BorderThickness.Button">1</Thickness>
    <Thickness x:Key="Style.Margin.Section">4</Thickness>
    <System:Double x:Key="Style.FontSize.Normal"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>
    <System:Double x:Key="Style.FontSize.Header"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">18</System:Double>
    <System:Double x:Key="Style.FontSize.Menu"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>

    <!-- ── Opacity tokens ────────────────────────────────────────────── -->
    <System:Double x:Key="Style.Opacity.Secondary"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">0.82</System:Double>

    <!-- ── Window chrome ─────────────────────────────────────────────── -->
    <CornerRadius x:Key="Style.Window.CornerRadius">0</CornerRadius>

    <!-- ══════════════════════════════════════════════════════════════════
         STYLE ROUTING – Modern versions with rounded corners,
         accent-tinted borders, softer hover effects, and refined spacing.
         ══════════════════════════════════════════════════════════════════ -->

    <!-- ── Modern Title Bar Button ─────────────────────────────────── -->
    <Style x:Key="Style.TitleBarButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="Transparent"
                            CornerRadius="4"
                            BorderThickness="0"
                            Margin="2,4"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Title Bar Close Button ───────────────────────────── -->
    <Style x:Key="Style.TitleBarCloseButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="Transparent"
                            CornerRadius="4"
                            BorderThickness="0"
                            Margin="2,4"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="#e81123" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background" Value="#f16f7a" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Window Main Panel ────────────────────────────────── -->
    <Style x:Key="Style.WindowMainPanel" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}" Value="Maximized">
                <Setter Property="BorderThickness" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ── Modern Header Panel (info bar below title bar) ──────────── -->
    <Style x:Key="Style.HeaderPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="Padding" Value="14,10,14,10" />
    </Style>

    <!-- ── Modern Live Ping Latency Badge ──────────────────────────── -->
    <Style x:Key="Style.LivePingLatencyBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <!-- ── Modern Live Ping Status Block ───────────────────────────── -->
    <Style x:Key="Style.LivePingStatusBlock" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ── Modern Live Ping Stat Segment (footer counter card) ─────── -->
    <Style x:Key="Style.LivePingStatSegment" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <!-- ── Modern Live Ping Log Row (left-accent indicator) ────────── -->
    <Style x:Key="Style.LivePingLogRow" TargetType="{x:Type Border}">
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="CornerRadius" Value="2,0,0,2" />
        <Setter Property="Padding" Value="8,2,6,2" />
        <Setter Property="Margin" Value="2,1,2,0" />
    </Style>

    <!-- ── Modern Live Ping Toolbar Separator ──────────────────────── -->
    <Style x:Key="Style.LivePingToolbarSeparator" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="8,2" />
        <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
    </Style>

    <!-- ── Modern Button (primary / dark) ──────────────────────────── -->
    <Style x:Key="Style.Button" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.AccentForeground}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="5"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="contentPresenter"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.75" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.40" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Standard Button (secondary – the most used button) ── -->
    <Style x:Key="Style.ButtonStandard" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="5"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="contentPresenter"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDefaulted" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.AccentHover}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.40" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Live Ping Footer Button ──────────────────────────── -->
    <Style x:Key="Style.LivePingFooterButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="5"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Live Ping Action Button (header buttons) ─────────── -->
    <Style x:Key="Style.LivePingActionButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="4"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Menu Popup Border ────────────────────────────────── -->
    <Style x:Key="Style.MenuPopupBorder" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,6" />
    </Style>

    <!-- ── Modern Content Panel (accent-bordered card surface) ─────── -->
    <Style x:Key="Style.ContentPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,16" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Margin" Value="6,8" />
    </Style>

    <!-- ── Modern Footer Panel ────────────────────────────────────── -->
    <Style x:Key="Style.FooterPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="0,2,0,0" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <!-- ── Modern Compact Row (card-like host row in Compact mode) ── -->
    <Style x:Key="Style.CompactRow" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="2,1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- ── Modern Compact Latency Badge ────────────────────────────── -->
    <Style x:Key="Style.CompactLatencyBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="Margin" Value="6,0,0,0" />
    </Style>

</ResourceDictionary>
