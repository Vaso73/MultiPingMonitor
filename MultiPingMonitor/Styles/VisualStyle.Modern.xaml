<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        VisualStyle.Modern
        A cleaner, modern dark-dashboard aesthetic with softer corners,
        more generous spacing, and refined typography hierarchy.
        Still a technical monitoring tool – not flashy, just polished.
    -->

    <!-- ── Layout tokens ─────────────────────────────────────────────── -->
    <CornerRadius x:Key="Style.CornerRadius">6</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Small">4</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Button">4</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Menu">6</CornerRadius>
    <Thickness x:Key="Style.Padding.Button">8,4</Thickness>
    <Thickness x:Key="Style.Padding.MenuItem">8,5,8,5</Thickness>
    <Thickness x:Key="Style.Padding.Header">14,10</Thickness>
    <Thickness x:Key="Style.BorderThickness">1</Thickness>
    <Thickness x:Key="Style.BorderThickness.Button">1</Thickness>
    <Thickness x:Key="Style.Margin.Section">2</Thickness>
    <System:Double x:Key="Style.FontSize.Normal"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>
    <System:Double x:Key="Style.FontSize.Header"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">18</System:Double>
    <System:Double x:Key="Style.FontSize.Menu"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>

    <!-- ── Opacity tokens ────────────────────────────────────────────── -->
    <System:Double x:Key="Style.Opacity.Secondary"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">0.85</System:Double>

    <!-- ── Window chrome ─────────────────────────────────────────────── -->
    <CornerRadius x:Key="Style.Window.CornerRadius">0</CornerRadius>

    <!-- ══════════════════════════════════════════════════════════════════
         MODERN BUTTON STYLE
         Rounded corners, slightly larger padding, softer hover transition.
         ══════════════════════════════════════════════════════════════════ -->
    <Style x:Key="ButtonStyle.Modern" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="4"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="contentPresenter"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.AccentHover}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         MODERN STANDARD BUTTON STYLE (secondary / muted)
         ══════════════════════════════════════════════════════════════════ -->
    <Style x:Key="ButtonStandardStyle.Modern" TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonStyle.Modern}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         MODERN MENU / CONTEXT MENU POPUP BORDER
         Rounded popup with subtle shadow appearance.
         ══════════════════════════════════════════════════════════════════ -->
    <Style x:Key="ModernMenuBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2,4" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         MODERN WINDOW MAIN PANEL STYLE
         Rounded corners on the outer border when not maximized.
         ══════════════════════════════════════════════════════════════════ -->
    <Style x:Key="WindowMainPanelStyle.Modern" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}" Value="Maximized">
                <Setter Property="BorderThickness" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         MODERN TITLE BAR BUTTON STYLE
         Rounded hover highlight.
         ══════════════════════════════════════════════════════════════════ -->
    <Style x:Key="TitleBarButtonStyle.Modern" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="Transparent"
                            CornerRadius="4"
                            BorderThickness="0"
                            Margin="2,4"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         MODERN TITLE BAR CLOSE BUTTON STYLE
         ══════════════════════════════════════════════════════════════════ -->
    <Style x:Key="TitleBarCloseButtonStyle.Modern" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="Transparent"
                            CornerRadius="4"
                            BorderThickness="0"
                            Margin="2,4"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="#e81123" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background" Value="#f16f7a" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         MODERN LIVE PING MONITOR FOOTER BUTTON STYLE
         Theme-aware rounded buttons for Stop/Clear/Close actions.
         ══════════════════════════════════════════════════════════════════ -->
    <Style x:Key="LivePingFooterButton.Modern" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="4"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.AccentHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
