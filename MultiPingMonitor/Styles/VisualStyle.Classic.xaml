<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        VisualStyle.Classic
        Preserves the original MultiPingMonitor look. All tokens intentionally
        mirror the existing hardcoded values so that switching to Classic
        produces zero visual change from the pre-feature baseline.

        Style routing keys (Style.XXX) point to the original styles already defined
        in the base resource dictionaries, ensuring no visual regression.
    -->

    <!-- ── Layout tokens ─────────────────────────────────────────────── -->
    <CornerRadius x:Key="Style.CornerRadius">0</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Small">0</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Button">0</CornerRadius>
    <CornerRadius x:Key="Style.CornerRadius.Menu">0</CornerRadius>
    <Thickness x:Key="Style.Padding.Button">3</Thickness>
    <Thickness x:Key="Style.Padding.MenuItem">6,4,6,4</Thickness>
    <Thickness x:Key="Style.Padding.Header">12,8</Thickness>
    <Thickness x:Key="Style.BorderThickness">1</Thickness>
    <Thickness x:Key="Style.BorderThickness.Button">1</Thickness>
    <Thickness x:Key="Style.Margin.Section">0</Thickness>
    <System:Double x:Key="Style.FontSize.Normal"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>
    <System:Double x:Key="Style.FontSize.Header"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">18</System:Double>
    <System:Double x:Key="Style.FontSize.Menu"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>

    <!-- ── Opacity tokens ────────────────────────────────────────────── -->
    <System:Double x:Key="Style.Opacity.Secondary"
                   xmlns:System="clr-namespace:System;assembly=mscorlib">1.0</System:Double>

    <!-- ── Window chrome ─────────────────────────────────────────────── -->
    <CornerRadius x:Key="Style.Window.CornerRadius">0</CornerRadius>

    <!-- ── Shared titlebar title style (all custom-chrome windows) ─── -->
    <Style x:Key="Style.TitleBar.Title" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         STYLE ROUTING – Classic versions replicate the original styles
         from WindowChrome.xaml/ButtonStyle.xaml so this dictionary is
         self-contained and does not depend on merge order.
         ══════════════════════════════════════════════════════════════════ -->

    <!-- Title bar button: Classic (replica of TitleBarButtonStyle) -->
    <Style x:Key="Style.TitleBarButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="Transparent"
                            BorderThickness="0"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title bar close button: Classic (replica of TitleBarCloseButtonStyle) -->
    <Style x:Key="Style.TitleBarCloseButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="Transparent"
                            BorderThickness="0"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="#e81123" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background" Value="#f16f7a" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Pin / always-on-top toggle button: Classic (TargetType=ToggleButton) -->
    <Style x:Key="Style.PinToggleButton" TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="border"
                            Background="Transparent"
                            BorderThickness="0"
                            SnapsToDevicePixels="true">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window main panel: Classic (replica of WindowMainPanelStyle) -->
    <Style x:Key="Style.WindowMainPanel" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}" Value="Maximized">
                <Setter Property="BorderThickness" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ── Header panel: Classic (conservative, matches original) ──── -->
    <Style x:Key="Style.HeaderPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <!-- ── Live Ping Latency Badge: Classic (no decoration) ────────── -->
    <Style x:Key="Style.LivePingLatencyBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <!-- ── Live Ping Status Block: Classic (no decoration) ─────────── -->
    <Style x:Key="Style.LivePingStatusBlock" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ── Live Ping Stat Segment: Classic (flat, no card) ─────────── -->
    <Style x:Key="Style.LivePingStatSegment" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,0,10,0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- ── Live Ping Log Row: Classic (flat, no indicator) ─────────── -->
    <Style x:Key="Style.LivePingLogRow" TargetType="{x:Type Border}">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- ── Live Ping Toolbar Separator: Classic (subtle line) ──────── -->
    <Style x:Key="Style.LivePingToolbarSeparator" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="6,2" />
        <Setter Property="Background" Value="{DynamicResource Theme.Border}" />
    </Style>

    <!-- Buttons: Classic dark (replica of ButtonStyle.Dark) -->
    <Style x:Key="Style.Button" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#3f3f46"/>
        <Setter Property="BorderBrush" Value="#abadb3"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter x:Name="contentPresenter"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="border" Value="#54545c"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" TargetName="border" Value="#007acc"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="#1c97ea"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" TargetName="border" Value="#d0d0d0"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="#FFADB2B5"/>
                            <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="#808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Standard button: Classic (replica of ButtonStandardStyle) -->
    <Style x:Key="Style.ButtonStandard" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#e1e1e1"/>
        <Setter Property="BorderBrush" Value="#abadb3"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter x:Name="contentPresenter"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDefaulted" Value="True">
                            <Setter Property="BorderBrush" TargetName="border" Value="#007acc"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="border" Value="#c9def5"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="#303030"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" TargetName="border" Value="#fafafa"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" TargetName="border" Value="#d0d0d0"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="#FFADB2B5"/>
                            <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="#808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Live Ping footer buttons: match original inline style with explicit template -->
    <Style x:Key="Style.LivePingFooterButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="0"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.SurfaceAlt}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Border}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Live Ping header action buttons: match original inline style with explicit template -->
    <Style x:Key="Style.LivePingActionButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            CornerRadius="0"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.SurfaceAlt}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Border}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource Theme.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu popup border: no corner radius, standard look -->
    <Style x:Key="Style.MenuPopupBorder" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <!-- ── Content panel: Classic (no extra decoration) ───────────────── -->
    <Style x:Key="Style.ContentPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- ── Footer panel: Classic ──────────────────────────────────────── -->
    <Style x:Key="Style.FooterPanel" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="9" />
    </Style>

    <!-- ── Compact row: Classic (flat, original look) ─────────────────── -->
    <Style x:Key="Style.CompactRow" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- ── Compact Set Toolbar strip: Classic ──────────────────────────── -->
    <Style x:Key="Style.CompactSetToolbar" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ── Compact latency badge: Classic (no decoration) ─────────────── -->
    <Style x:Key="Style.CompactLatencyBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="4,0,0,0" />
    </Style>

    <!-- ── Classic Probe Card spacing tokens (original tight spacing) ─── -->
    <Thickness x:Key="Style.ProbeCardAlias.Padding">6,5,4,5</Thickness>
    <Thickness x:Key="Style.ProbeCardGlyph.Padding">6,0,2,0</Thickness>
    <Thickness x:Key="Style.ProbeCardHostname.Padding">2,5,0,5</Thickness>
    <Thickness x:Key="Style.ProbeCardStatsLabel.Padding">6,2,0,4</Thickness>
    <Thickness x:Key="Style.ProbeCardStatsLabel.Margin">6,0,0,0</Thickness>

    <!-- ── Classic Probe Card grid / card corner radius tokens ─────────── -->
    <Thickness x:Key="Style.ProbeCardGrid.Margin">0,0,-2,-2</Thickness>
    <CornerRadius x:Key="Style.ProbeCardHeader.CornerRadius">0</CornerRadius>

    <!-- ── Classic Probe Card outer divider border ───────────────────── -->
    <Style x:Key="Style.ProbeCard" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="0,0,2,2" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- ── Classic Probe Card stats band (flat, transparent) ────────── -->
    <Style x:Key="Style.ProbeCardStats" TargetType="{x:Type DockPanel}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Path=Type}" Value="Ping">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=Statistics.Sent}" Value="0">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ── Classic Probe Card footer row (subtle border, square) ────── -->
    <Style x:Key="Style.ProbeCardFooter" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- ── Classic Title-Bar Separator (subtle line below menu bar) ──── -->
    <Style x:Key="Style.TitleBarSeparator" TargetType="{x:Type Border}">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Theme.Border}" />
    </Style>

    <!-- ── Classic Menu Sub-Popup Border (no rounding, standard look) ── -->
    <Style x:Key="Style.MenuSubPopupBorder" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <!-- ── Classic Menu Item hover tokens (conservative per-style hover) ── -->
    <SolidColorBrush x:Key="Style.MenuItem.Hover.Background"   Color="{DynamicResource Theme.SurfaceAlt.Color}"/>
    <SolidColorBrush x:Key="Style.MenuItem.Hover.BorderBrush"  Color="{DynamicResource Theme.Border.Color}"/>
    <SolidColorBrush x:Key="Style.MenuItem.Hover.Foreground"   Color="{DynamicResource Theme.Text.Primary.Color}"/>

    <!-- ── Classic Header Toggle Button (e.g. Always-on-top in LPMW header) ── -->
    <Style x:Key="Style.HeaderToggleButton" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background"   Value="{DynamicResource Theme.SurfaceAlt}" />
        <Setter Property="BorderBrush"  Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"      Value="5,2" />
        <Setter Property="FontSize"     Value="11" />
        <Setter Property="Cursor"       Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="ToggleBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Style.CornerRadius.Small}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Border}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ToggleBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Accent}" />
                            <Setter TargetName="ToggleBorder" Property="BorderThickness" Value="2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Classic Context Menu (square popup, standard look) ──────── -->
    <Style x:Key="Style.ContextMenu" TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                        Grid.IsSharedSizeScope="True"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                        KeyboardNavigation.TabNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

