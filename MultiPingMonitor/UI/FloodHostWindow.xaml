<Window x:Class="MultiPingMonitor.UI.FloodHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MultiPingMonitor.UI"
        xmlns:classes="clr-namespace:MultiPingMonitor.Classes"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="{x:Static resource:Strings.FloodHost_Title}"
        UseLayoutRounding="True"
        Height="250"
        Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme.Background}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Flood Host specific converter (localized in code-behind) -->
        <classes:BoolToStringConverter x:Key="BoolToStringConverter" FalseValue="Flood Host" TrueValue="Stop Flood"/>
    </Window.Resources>

    <Border Style="{StaticResource WindowMainPanelStyle}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="16" Height="16" Margin="8,0,4,0"
                   Source="/Resources/bomb-16.png" />
            <TextBlock Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13"
                       Foreground="{DynamicResource Theme.Text.Primary}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button Grid.Column="2" Click="OnCloseButtonClick"
                    Style="{StaticResource TitleBarCloseButtonStyle}" AutomationProperties.Name="Close"
                    ToolTip="Close" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Theme.Border}" />

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Hostname textbox -->
            <TextBox Name="txtHostname"
                     FontSize="18" FontWeight="Bold"
                     VerticalContentAlignment="Center"
                     IsEnabled="{Binding IsActive, Converter={StaticResource InverseBooleanConverter}}"
                     />

            <!-- Flood Host button -->
            <Button Name="btnFloodHost"
                    Click="btnFloodHost_Click"
                    Grid.Column="1"
                    IsDefault="True"
                    Margin="10,0,0,0"
                    Padding="8,6"
                    MinWidth="125"
                    Style="{StaticResource ButtonStyle}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="{Binding IsActive, Converter={StaticResource BooleanToImageConverter}}"
                           Margin="0,0,8,0" Width="16" Height="16" />
                    <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToStringConverter}}" />
                </StackPanel>
            </Button>
        </Grid>


        <Grid Grid.Row="1" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Static resource:Strings.FloodHost_PacketsSent}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,15,0"
                           Foreground="{DynamicResource Theme.Text.Secondary}"
                           FontSize="16" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Name="tbPacketsSent"
                           Text="{Binding Path=PacketsSent, StringFormat='#,0'}"
                           Foreground="{DynamicResource Theme.Info}"
                           FontSize="22" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Static resource:Strings.FloodHost_PacketsReceived}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,15,0"
                           Foreground="{DynamicResource Theme.Text.Secondary}"
                           FontSize="16" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Name="tbPacketsReceived"
                           Text="{Binding Path=PacketsReceived, StringFormat='#,0'}"
                           Foreground="{DynamicResource Theme.Success}"
                           FontSize="22" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Static resource:Strings.FloodHost_PacketsLost}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,15,0"
                           Foreground="{DynamicResource Theme.Text.Secondary}"
                           FontSize="16" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Name="tbPacketsLost"
                           Text="{Binding Path=PacketsLost, StringFormat='#,0'}"
                           Foreground="{DynamicResource Theme.Danger}"
                           FontSize="22" />
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" Text="{x:Static resource:Strings.FloodHost_InProgress}"
                   Name="tbStatus"
                   Margin="0,7" HorizontalAlignment="Center"
                   Foreground="{DynamicResource Theme.Text.Secondary}"
                   FontSize="13"
                   Visibility="{Binding IsActive, Converter={StaticResource BooleanToHiddenVisibilityConverter}}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True" >
                                        <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Opacity)"
                                                         From="1" To=".2"
                                                         BeginTime="0:0:1.25"
                                                         Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Opacity)"
                                                         From="1" To="1" Duration="0:0:0.0" FillBehavior="HoldEnd" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Label Grid.Row="1" Grid.RowSpan="2"
               VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
               Name="lblInformation"
               Foreground="{DynamicResource Theme.Text.Secondary}"
               Background="{DynamicResource Theme.Background}"
               Padding="40,0"
               FontSize="14">
            <TextBlock TextWrapping="Wrap" TextAlignment="Justify" Text="{x:Static resource:Strings.FloodHost_Description}"/>
        </Label>

    </Grid>
    </DockPanel>
    </Border>
</Window>
