<Window x:Class="MultiPingMonitor.UI.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="{x:Static resource:Strings.Help_Title}"
        UseLayoutRounding="True"
        Height="600"
        Width="780"
        MinHeight="400"
        MinWidth="550"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Theme.Background}"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        </Style>
        <Style TargetType="Paragraph">
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="FontFamily" Value="Segoe UI, Arial" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- Title style -->
        <Style x:Key="TitleText"
               BasedOn="{StaticResource {x:Type TextBlock}}"
               TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
        </Style>

        <!-- HyperLink style -->
        <Style x:Key="HyperlinkStyle"
               BasedOn="{StaticResource {x:Type Hyperlink}}"
               TargetType="Hyperlink">
            <Setter Property="TextDecorations" Value="None" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Accent}" />
        </Style>

        <!-- Version style -->
        <Style x:Key="VersionText"
               BasedOn="{StaticResource {x:Type Paragraph}}"
               TargetType="Paragraph">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <!-- Section header style -->
        <Style x:Key="HeaderText"
               BasedOn="{StaticResource {x:Type Paragraph}}"
               TargetType="Paragraph">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,30,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Accent}" />
            <Setter Property="FontSize" Value="22" />
        </Style>

        <!-- Sub-header style -->
        <Style x:Key="SubHeaderText"
               BasedOn="{StaticResource {x:Type Paragraph}}"
               TargetType="Paragraph">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,20,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <!-- Paragraph style -->
        <Style x:Key="ParagraphText"
               BasedOn="{StaticResource {x:Type Paragraph}}"
               TargetType="Paragraph">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
        </Style>

        <!-- TreeView theme-aware style -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{DynamicResource Theme.Surface}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="130" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TreeView Name="tree" FontSize="10pt" Padding="8,16,12,16" Margin="0">
            <TreeViewItem Header="{x:Static resource:Strings.Help_Nav_Intro}"
                          Selected="Intro_Selected" />
            <TreeViewItem Header="{x:Static resource:Strings.Help_Nav_BasicUsage}"
                          Selected="BasicUsage_Selected" />
            <TreeViewItem Header="{x:Static resource:Strings.Help_Nav_ExtraFeatures}"
                          Selected="ExtraFeatures_Selected" />
            <TreeViewItem Header="{x:Static resource:Strings.Help_Nav_Options}"
                          Selected="Options_Selected" />
            <TreeViewItem Header="{x:Static resource:Strings.Help_Nav_CommandLine}"
                          Selected="CommandLineUsage_Selected" />
        </TreeView>
        <GridSplitter Grid.Column="1" Width="1"
                      HorizontalAlignment="Center"
                      Background="{DynamicResource Theme.Border}"
                      BorderThickness="0"
                      VerticalAlignment="Stretch" />

        <FlowDocumentScrollViewer Name="MainDocument" Grid.Column="2"
                                  Background="{DynamicResource Theme.Background}"
                                  Foreground="{DynamicResource Theme.Text.Primary}"
                                  FocusVisualStyle="{x:Null}">
            <FlowDocument>
                <!-- Logo and title -->
                <BlockUIContainer>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,16">
                        <Image Source="/MultiPingMonitor.ico" Width="32" Height="32" Margin="0,0,12,0" />
                        <TextBlock Style="{StaticResource TitleText}"
                                   VerticalAlignment="Center"
                                   Text="MultiPingMonitor" />
                    </StackPanel>
                </BlockUIContainer>

                <!-- Link to homepage -->
                <Paragraph TextAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/Vaso73/MultiPingMonitor"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Style="{StaticResource HyperlinkStyle}">
                        https://github.com/Vaso73/MultiPingMonitor
                    </Hyperlink>
                </Paragraph>

                <!-- Version -->
                <Paragraph Name="Version"
                           Style="{StaticResource VersionText}"
                           Margin="0,3,0,0">
                    Version X.XXXX.XXXX
                </Paragraph>
                <Paragraph Name="Copyright"
                           Style="{StaticResource VersionText}">
                    Copyright
                </Paragraph>

                <!-- Intro section -->
                <BlockUIContainer>
                    <Rectangle Margin="0,24,0,0" HorizontalAlignment="Stretch" Fill="{DynamicResource Theme.Border}" Height="1" />
                </BlockUIContainer>
                <Paragraph Name="Intro" Margin="0,8"
                           Foreground="{DynamicResource Theme.Text.Primary}">
                    MultiPingMonitor is a network utility that allows you to quickly monitor the availability of multiple hosts.
                </Paragraph>
                <BlockUIContainer>
                    <Rectangle HorizontalAlignment="Stretch" Fill="{DynamicResource Theme.Border}" Height="1" />
                </BlockUIContainer>

                <!-- Basic Usage section -->
                <Paragraph Name="BasicUsage"
                           Style="{StaticResource HeaderText}">
                    Basic Usage
                </Paragraph>
                <Paragraph Name="Sub_AppOverview" Style="{StaticResource SubHeaderText}">
                    Application overview
                </Paragraph>
                <Paragraph Style="{StaticResource ParagraphText}">

                </Paragraph>
                <Paragraph Name="Sub_MonitorHost" Style="{StaticResource SubHeaderText}">
                    Monitor a host
                </Paragraph>
                <Paragraph Name="Para_MonitorHost" Style="{StaticResource ParagraphText}">
                    Monitor a host
                </Paragraph>
                <Paragraph Name="Sub_AddHost" Style="{StaticResource SubHeaderText}">
                    Add a host monitor
                </Paragraph>
                <Paragraph Name="Para_AddHost" Style="{StaticResource ParagraphText}">
                    Add a host monitor
                </Paragraph>
                <Paragraph Name="Sub_RemoveHost" Style="{StaticResource SubHeaderText}">
                    Remove a host monitor
                </Paragraph>
                <Paragraph Name="Para_RemoveHost" Style="{StaticResource ParagraphText}">
                    Remove a host monitor
                </Paragraph>
                <Paragraph Name="Sub_Columns" Style="{StaticResource SubHeaderText}">
                    Columns
                </Paragraph>
                <Paragraph Name="Para_Columns" Style="{StaticResource ParagraphText}">
                    Columns
                </Paragraph>

                <!-- Extra Features section -->
                <Paragraph Name="ExtraFeatures"
                           Style="{StaticResource HeaderText}">
                    Extra Features
                </Paragraph>
                <Paragraph Name="Sub_PortMonitor" Style="{StaticResource SubHeaderText}">
                    Port Monitor
                </Paragraph>
                <Paragraph Name="Para_PortMonitor" Style="{StaticResource ParagraphText}">
                    Port Monitor
                </Paragraph>
                <Paragraph Name="Sub_TraceRoute" Style="{StaticResource SubHeaderText}">
                    Traceroute
                </Paragraph>
                <Paragraph Name="Para_TraceRoute" Style="{StaticResource ParagraphText}">
                    Traceroute
                </Paragraph>
                <Paragraph Name="Sub_FloodHostHelp" Style="{StaticResource SubHeaderText}">
                    Flood Host
                </Paragraph>
                <Paragraph Name="Para_FloodHostHelp" Style="{StaticResource ParagraphText}">
                    Flood Host
                </Paragraph>

                <!-- Options section -->
                <Paragraph Name="Options"
                           Style="{StaticResource HeaderText}">
                    Options
                </Paragraph>
                <Paragraph Name="Sub_PingIntervalHelp" Style="{StaticResource SubHeaderText}">
                    Ping interval
                </Paragraph>
                <Paragraph Name="Para_PingIntervalHelp" Style="{StaticResource ParagraphText}">
                    Ping interval
                </Paragraph>
                <Paragraph Name="Sub_PingTimeoutHelp" Style="{StaticResource SubHeaderText}">
                    Ping timeout
                </Paragraph>
                <Paragraph Name="Para_PingTimeoutHelp" Style="{StaticResource ParagraphText}">
                    Ping timeout
                </Paragraph>
                <Paragraph Name="Sub_SendEmailHelp" Style="{StaticResource SubHeaderText}">
                    Send email
                </Paragraph>
                <Paragraph Name="Para_SendEmailHelp" Style="{StaticResource ParagraphText}">
                    Send email
                </Paragraph>
                <Paragraph Name="Sub_AlwaysOnTopHelp" Style="{StaticResource SubHeaderText}">
                    Always on top
                </Paragraph>
                <Paragraph Name="Para_AlwaysOnTopHelp" Style="{StaticResource ParagraphText}">
                    Always on top
                </Paragraph>
                <Paragraph Name="Sub_LogOutputHelp" Style="{StaticResource SubHeaderText}">
                    Log output
                </Paragraph>
                <Paragraph Name="Para_LogOutputHelp" Style="{StaticResource ParagraphText}">
                    Log output
                </Paragraph>
                <Paragraph Name="Sub_StartInTrayHelp" Style="{StaticResource SubHeaderText}">
                    Start in tray
                </Paragraph>
                <Paragraph Name="Para_StartInTrayHelp" Style="{StaticResource ParagraphText}">
                    Start in tray
                </Paragraph>
                <Paragraph Name="Sub_LanguageHelp" Style="{StaticResource SubHeaderText}">
                    Language
                </Paragraph>
                <Paragraph Name="Para_LanguageHelp" Style="{StaticResource ParagraphText}">
                    Language
                </Paragraph>
                <Paragraph Name="Sub_PortableConfigHelp" Style="{StaticResource SubHeaderText}">
                    Portable configuration
                </Paragraph>
                <Paragraph Name="Para_PortableConfigHelp" Style="{StaticResource ParagraphText}">
                    Portable configuration
                </Paragraph>
                <Paragraph Name="Sub_TrayBehaviorHelp" Style="{StaticResource SubHeaderText}">
                    System tray
                </Paragraph>
                <Paragraph Name="Para_TrayBehaviorHelp" Style="{StaticResource ParagraphText}">
                    System tray
                </Paragraph>

                <!-- Command Line Usage section -->
                <Paragraph Name="CommandLineUsage"
                           Style="{StaticResource HeaderText}">
                    Command Line Usage
                </Paragraph>
                <Paragraph Name="Sub_CommandLineUsageHelp" Style="{StaticResource SubHeaderText}">
                    Usage: MultiPingMonitor [-i interval] [-w timeout] [&lt;target_host&gt;...]
                </Paragraph>
            </FlowDocument>
        </FlowDocumentScrollViewer>
    </Grid>
</Window>
