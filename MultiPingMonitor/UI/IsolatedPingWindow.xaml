<Window x:Class="MultiPingMonitor.UI.IsolatedPingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Hostname, StringFormat='{}{0} - MultiPingMonitor'}"
        UseLayoutRounding="True"
        WindowStyle="None"
        Height="500"
        Width="450"
        MinHeight="200"
        MinWidth="300"
        Background="{DynamicResource Theme.Background}"
        Closed="Window_Closed">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
        <DockPanel Background="{DynamicResource Theme.Background}">

            <!-- Title bar -->
            <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Window icon -->
                <Image Grid.Column="0" Source="{StaticResource icon.vmping-logo-simple}" Width="16" Height="16" Margin="8,0,4,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <!-- Title text (hostname) -->
                <TextBlock Grid.Column="1" Style="{DynamicResource Style.TitleBar.Title}"
                           Text="{Binding Hostname}" />
                <!-- Minimize -->
                <Button Grid.Column="2" Style="{DynamicResource Style.TitleBarButton}"
                        Width="46" Click="MinimizeButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="46" Height="32" Data="M 18,15 H 28" Stretch="None"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" />
                </Button>
                <!-- Close -->
                <Button Grid.Column="3" Style="{DynamicResource Style.TitleBarCloseButton}"
                        Width="46" Click="CloseButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11" Stretch="None"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" />
                </Button>
            </Grid>

            <!-- Hostname header -->
            <Border DockPanel.Dock="Top" Style="{DynamicResource Style.HeaderPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!-- Hostname (primary) -->
                    <TextBlock Grid.Row="0" Text="{Binding Hostname}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.Text.Primary}"
                               TextTrimming="CharacterEllipsis" />
                    <!-- Action toolbar row (mirrors LivePingMonitorWindow header toolbar) -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                        <ToggleButton x:Name="AlwaysOnTopCheckBox"
                                      Style="{DynamicResource Style.HeaderToggleButton}"
                                      VerticalAlignment="Center"
                                      Checked="AlwaysOnTopCheckBox_Changed"
                                      Unchecked="AlwaysOnTopCheckBox_Changed">
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="PinIcon" Width="10" Height="12" Stretch="Uniform"
                                      Fill="{DynamicResource Theme.Text.Secondary}" VerticalAlignment="Center"
                                      Data="M7,0 L9,0 9,4 12,6 12,8 8,8 8,14 7,14 7,8 3,8 3,6 7,4 Z" />
                                <TextBlock x:Name="AlwaysOnTopText" Text="Always on top" Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Theme.Text.Primary}" />
                            </StackPanel>
                        </ToggleButton>
                        <Border Style="{DynamicResource Style.LivePingToolbarSeparator}" />
                        <Button x:Name="CopyTargetButton" Click="CopyTargetButton_Click"
                                Style="{DynamicResource Style.LivePingActionButton}"
                                Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="10" Height="11" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{DynamicResource Theme.Text.Secondary}"
                                      Data="M4,0 L4,1 1,1 1,11 9,11 9,4 10,4 10,12 0,12 0,0 Z M3,0 L3,8 11,8 11,0 Z M4,1 L10,1 10,7 4,7 Z" />
                                <TextBlock x:Name="CopyTargetText" Text="Copy Target" Margin="4,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stats footer (Ping only, hidden when Sent == 0) -->
            <Border DockPanel.Dock="Bottom">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=Type}" Value="Ping">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=Statistics.Sent}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border Style="{DynamicResource Style.FooterPanel}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{DynamicResource Style.LivePingStatSegment}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Sent" FontSize="11"
                                           Foreground="{DynamicResource Theme.Text.Secondary}"
                                           VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource Theme.Info}"
                                           VerticalAlignment="Center"
                                           Text="{Binding Statistics.Sent, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     AutoReverse="True"
                                                                     From="1.0" To="0.75" Duration="0:0:0.3"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource Style.LivePingStatSegment}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Recv" FontSize="11"
                                           Foreground="{DynamicResource Theme.Text.Secondary}"
                                           VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource Theme.Success}"
                                           VerticalAlignment="Center"
                                           Text="{Binding Statistics.Received, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     AutoReverse="True"
                                                                     From="1.0" To="0.75" Duration="0:0:0.3"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource Style.LivePingStatSegment}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Lost" FontSize="11"
                                           Foreground="{DynamicResource Theme.Text.Secondary}"
                                           VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource Theme.Danger}"
                                           VerticalAlignment="Center"
                                           Text="{Binding Statistics.Lost, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     AutoReverse="True"
                                                                     From="1.0" To="0.75" Duration="0:0:0.3"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Ping history (status-tinted background) -->
            <Border Background="{Binding Status, Converter={StaticResource ProbeStatusToBackgroundBrushConverter}}"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0">
                <TextBox x:Name="History"
                         IsReadOnly="True"
                         IsTabStop="False"
                         Background="Transparent"
                         Foreground="{Binding Status, Converter={StaticResource ProbeStatusToForegroundBrushConverter}}"
                         HorizontalScrollBarVisibility="Disabled"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         BorderThickness="0"
                         Cursor="Arrow"
                         IsInactiveSelectionHighlightEnabled="True"
                         SelectionBrush="Black"
                         SelectionOpacity="0.4"
                         TextChanged="History_TextChanged"
                         SelectionChanged="History_SelectionChanged"
                         FontFamily="Consolas"
                         FontSize="{Binding Type, Converter={StaticResource ProbeTypeToFontSizeConverter}}"
                         Text="{Binding Path=HistoryAsString, Mode=OneWay}">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}">
                            <Setter Property="Opacity" Value="0.4"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Opacity" Value="1.0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Border>

        </DockPanel>
    </Border>
</Window>
