<Window x:Class="MultiPingMonitor.UI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MultiPingMonitor"
        UseLayoutRounding="True"
        WindowStyle="None"
        Width="560"
        Height="430"
        MinWidth="520"
        MinHeight="410"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme.Background}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
        <DockPanel Background="{DynamicResource Theme.Background}">
            <Grid DockPanel.Dock="Top"
                  Height="32"
                  Background="{DynamicResource Theme.Surface}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Style="{DynamicResource Style.TitleBar.Title}"
                           Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />

                <Button Grid.Column="1"
                        Click="CloseButton_Click"
                        Style="{DynamicResource Style.TitleBarCloseButton}"
                        AutomationProperties.Name="Close"
                        ToolTip="Close"
                        ToolTipService.InitialShowDelay="1000">
                    <Path Width="46"
                          Height="32"
                          Data="M 18,11 27,20 M 18,20 27,11"
                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1" />
                </Button>
            </Grid>

            <Border DockPanel.Dock="Top"
                    Style="{DynamicResource Style.TitleBarSeparator}" />

            <Border DockPanel.Dock="Bottom"
                    Style="{DynamicResource Style.FooterPanel}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10">
                    <Button x:Name="OpenReleasesButton"
                            Style="{DynamicResource Style.ButtonStandard}"
                            Width="190"
                            Visibility="Collapsed"
                            Click="OpenReleasesButton_Click" />

                    <Button x:Name="CheckForUpdatesButton"
                            Style="{DynamicResource Style.ButtonStandard}"
                            Width="170"
                            Margin="8,0,0,0"
                            Click="CheckForUpdatesButton_Click" />

                    <Button x:Name="CloseButton"
                            Style="{DynamicResource Style.ButtonStandard}"
                            Width="100"
                            Margin="8,0,0,0"
                            IsCancel="True"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Border>

            <Grid Margin="28,24,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Image Source="{DynamicResource icon.vmping-logo-simple}"
                           Width="54"
                           Height="54"
                           Margin="0,0,16,0" />

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MultiPingMonitor"
                                   Foreground="{DynamicResource Theme.Text.Primary}"
                                   FontSize="25"
                                   FontWeight="SemiBold" />

                        <TextBlock x:Name="EditionValueText"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource Theme.Text.Secondary}"
                                   FontSize="14" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,28,0,0"
                      HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="VersionLabelText"
                               Grid.Column="0"
                               Foreground="{DynamicResource Theme.Text.Secondary}"
                               FontSize="14"
                               Margin="0,0,8,0" />

                    <TextBlock x:Name="VersionValueText"
                               Grid.Column="1"
                               Foreground="{DynamicResource Theme.Text.Primary}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                </Grid>

                <ProgressBar x:Name="CheckProgress"
                             Grid.Row="2"
                             Height="4"
                             Margin="24,24,24,0"
                             IsIndeterminate="True"
                             Visibility="Collapsed" />

                <Border Grid.Row="3"
                        Margin="0,18,0,0"
                        Padding="18"
                        Background="{DynamicResource Theme.Surface}">
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Theme.Text.Primary}"
                               FontSize="13" />
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
