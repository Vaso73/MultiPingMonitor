<Window x:Class="MultiPingMonitor.UI.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="{x:Static resource:Strings.Options_Title}"
        UseLayoutRounding="True"
        WindowStyle="None"
        Height="640"
        Width="940"
        MinHeight="560"
        MinWidth="840"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource Theme.Background}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}" x:Key="OptionSubHeaderTextStyle">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.Accent}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="16" Height="16" Margin="8,0,4,0"
                   Source="{StaticResource icon.vmping-logo-simple}" />
            <TextBlock Grid.Column="1" Style="{DynamicResource Style.TitleBar.Title}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button x:Name="titleBarCloseButton" Grid.Column="2" Click="OnCloseButtonClick"
                    Style="{DynamicResource Style.TitleBarCloseButton}" AutomationProperties.Name=""
                    ToolTip="" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Style="{DynamicResource Style.TitleBarSeparator}" />

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabControl"
                    Grid.Row="0"
                    Style="{DynamicResource Style.SettingsTabControl}"
                    TabStripPlacement="Left">
            <!-- Tab: General -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_General}"
         Name="GeneralTab"
         Style="{DynamicResource Style.SettingsTabItem}"
         Tag="{StaticResource geom.menu.options}">
    <Border Style="{DynamicResource Style.SettingsPagePanel}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Focusable="False"
                      FocusVisualStyle="{x:Null}">
            <Grid Margin="8,0,8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{x:Static resource:Strings.Options_Tab_General}"
                           Style="{StaticResource OptionHeaderTextStyle}"
                           Margin="4,0,4,10"/>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{DynamicResource Style.SettingsCard}"
                            Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_Header_ProbeOptions}"
                                       Style="{DynamicResource Style.SettingsCardTitle}"/>

                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Static resource:Strings.Options_PingInterval}"
                                               Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Name="PingInterval"
                                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                                 Width="58"
                                                 MaxLength="5"/>
                                        <ComboBox Name="PingIntervalUnits"
                                                  Width="98"
                                                  Margin="8,0,0,0">
                                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Seconds}"
                                                          IsSelected="True"/>
                                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Minutes}"/>
                                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Hours}"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{x:Static resource:Strings.Options_PingTimeout}"
                                               Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Name="PingTimeout"
                                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                                 Width="58"
                                                 MaxLength="2"/>
                                        <TextBlock Text="{x:Static resource:Strings.Options_Seconds}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{x:Static resource:Strings.Options_AlertThreshold}"
                                               Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Name="AlertThreshold"
                                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                                 Width="44"
                                                 MaxLength="2"/>
                                        <TextBlock Text="{x:Static resource:Strings.Options_DroppedPings}"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{DynamicResource Style.SettingsCard}"
                            Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_Header_LatencyDetection}"
                                       Style="{DynamicResource Style.SettingsCardTitle}"/>

                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Static resource:Strings.Options_DetectionMode}"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Name="LatencyDetectionMode"
                                              Width="150"
                                              HorizontalAlignment="Left">
                                        <ComboBoxItem Content="{x:Static resource:Strings.Options_Off}"/>
                                        <ComboBoxItem Content="{x:Static resource:Strings.Options_Auto}"/>
                                        <ComboBoxItem Content="{x:Static resource:Strings.Options_Fixed}"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{x:Static resource:Strings.Options_HighLatency}"
                                               Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Name="HighLatencyMilliseconds"
                                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                                 Width="64"
                                                 MaxLength="6"/>
                                        <TextBlock Text="{x:Static resource:Strings.Options_Ms}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{x:Static resource:Strings.Options_LatencyTriggers}"
                                               Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Name="HighLatencyTriggerCount"
                                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                                 Width="64"
                                                 MaxLength="3"/>
                                        <TextBlock Text="{x:Static resource:Strings.Options_Probes}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{DynamicResource Style.SettingsCard}"
                            Padding="14,10">
                            <StackPanel>
                                <TextBlock x:Name="AutomaticUpdateHeader"
                                           Text="Updates"
                                           Style="{DynamicResource Style.SettingsCardTitle}"/>

                                <CheckBox x:Name="AutomaticUpdateCheckEnabled"
                                          Margin="0,0,0,8"
                                          Content="Automatically check for updates"/>

                                <StackPanel IsEnabled="{Binding IsChecked, ElementName=AutomaticUpdateCheckEnabled}">
                                    <TextBlock x:Name="AutomaticUpdateCheckFrequencyLabel"
                                               Text="Frequency:"
                                               Margin="0,0,0,4"/>
                                    <ComboBox x:Name="AutomaticUpdateCheckFrequency"
                                              Width="220"
                                              HorizontalAlignment="Left"/>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="LastAutomaticUpdateCheckLabel"
                                                   Text="Last check:"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock x:Name="LastAutomaticUpdateCheck"
                                                   Grid.Column="1"
                                                   Text="Never"
                                                   Foreground="{DynamicResource Theme.Text.Secondary}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{DynamicResource Style.SettingsCard}"
                            Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_Header_Startup}"
                                       Style="{DynamicResource Style.SettingsCardTitle}"/>

                            <TextBlock Text="{x:Static resource:Strings.Options_StartupPrompt}"
                                       Foreground="{DynamicResource Theme.Text.Secondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"/>

                            <ComboBox Name="StartupMode"
                                      Width="220"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem Content="{x:Static resource:Strings.Options_StartupBlank}"
                                              Tag="Standard"
                                              IsSelected="True"/>
                                <ComboBoxItem Content="{x:Static resource:Strings.Options_StartupListInput}"
                                              Tag="Standard"/>
                                <ComboBoxItem Content="{x:Static resource:Strings.Options_StartupFavorite}"
                                              Tag="Favorite"/>
                            </ComboBox>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0">
                                <StackPanel.Style>
                                    <Style>
                                        <Setter Property="StackPanel.Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=StartupMode, Path=SelectedItem.Tag}"
                                                         Value="Standard">
                                                <Setter Property="StackPanel.Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="{x:Static resource:Strings.Options_ProbeCount}"
                                               Margin="0,0,0,4"/>
                                    <TextBox Name="InitialProbeCount"
                                             PreviewTextInput="NumericTextbox_PreviewTextInput"
                                             Width="60"
                                             HorizontalAlignment="Left"
                                             MaxLength="2"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="{x:Static resource:Strings.Options_ColumnCount}"
                                               Margin="0,0,0,4"/>
                                    <TextBox Name="InitialColumnCount"
                                             PreviewTextInput="NumericTextbox_PreviewTextInput"
                                             Width="60"
                                             HorizontalAlignment="Left"
                                             MaxLength="2"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0">
                                <StackPanel.Style>
                                    <Style>
                                        <Setter Property="StackPanel.Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=StartupMode, Path=SelectedItem.Tag}"
                                                         Value="Favorite">
                                                <Setter Property="StackPanel.Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="{x:Static resource:Strings.Options_SelectFavorite}"
                                           Margin="0,0,0,4"/>
                                <ComboBox Name="InitialFavorite"
                                          Width="260"
                                          HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Border>
</TabItem>

            <!-- Tab: Advanced -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Advanced}"
         Name="AdvancedTab"
         Style="{DynamicResource Style.SettingsTabItem}"
         Tag="{StaticResource geom.menu.traceroute}">
    <Border Style="{DynamicResource Style.SettingsPagePanel}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Focusable="False"
                      FocusVisualStyle="{x:Null}">
            <Grid Margin="8,0,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{x:Static resource:Strings.Options_Header_AdvancedICMP}"
                           Style="{StaticResource OptionHeaderTextStyle}"
                           Margin="4,0,4,14"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{DynamicResource Style.SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_Header_AdvancedICMP}"
                                       Style="{DynamicResource Style.SettingsCardTitle}"/>

                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static resource:Strings.Options_TTL}"
                                           VerticalAlignment="Center"
                                           Margin="0,4,12,4"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Margin="0,4,0,4">
                                    <TextBox Name="TTL"
                                             PreviewTextInput="NumericTextbox_PreviewTextInput"
                                             Width="74"
                                             MaxLength="3"/>
                                    <TextBlock Text="{x:Static resource:Strings.Options_Hops}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <DockPanel LastChildFill="False"
                                       Margin="0,8,0,0">
                                <CheckBox DockPanel.Dock="Left"
                                          Name="DontFragment"
                                          Content="{x:Static resource:Strings.Options_DontFragment}"/>
                                <Label DockPanel.Dock="Left"
                                       Style="{StaticResource LabelToolTip}">
                                    <TextBlock Text="{x:Static resource:Strings.Tooltip_DontFragment}"
                                               TextWrapping="Wrap"/>
                                </Label>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{DynamicResource Style.SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_PacketDataSize}"
                                       Style="{DynamicResource Style.SettingsCardTitle}"/>

                            <Grid Margin="0,2,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <RadioButton Grid.Row="0"
                                             GroupName="IcmpData"
                                             Content="{x:Static resource:Strings.Options_PacketDataSize}"
                                             Name="PacketSizeOption"
                                             Checked="PacketSizeOption_Checked"
                                             IsChecked="True"
                                             Margin="0,4,0,4"/>

                                <StackPanel Grid.Row="1"
                                            Orientation="Horizontal"
                                            Margin="24,0,0,4">
                                    <TextBox Name="PacketSize"
                                             PreviewTextInput="NumericTextbox_PreviewTextInput"
                                             TextChanged="PacketData_TextChanged"
                                             Width="74"
                                             MaxLength="5"
                                             Visibility="{Binding IsChecked, ElementName=PacketSizeOption, Converter={StaticResource BooleanToHiddenVisibilityConverter}}"/>
                                    <TextBlock Text="{x:Static resource:Strings.Options_Bytes}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsChecked, ElementName=PacketSizeOption, Converter={StaticResource BooleanToHiddenVisibilityConverter}}"/>
                                </StackPanel>

                                <RadioButton Grid.Row="2"
                                             GroupName="IcmpData"
                                             Content="{x:Static resource:Strings.Options_CustomPacketData}"
                                             Name="UseCustomPacketOption"
                                             Checked="UseCustomPacketOption_Checked"
                                             Margin="0,6,0,4"/>
                            </Grid>

                            <TextBox Name="PacketData"
                                     TextChanged="PacketData_TextChanged"
                                     Height="72"
                                     Margin="0,6,0,0"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxLength="65500"
                                     Visibility="{Binding IsChecked, ElementName=UseCustomPacketOption, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,12,0,0">
                                <TextBlock Text="{x:Static resource:Strings.Options_TotalPacketSize}"/>
                                <TextBlock Name="Bytes"
                                           Text="64"
                                           Foreground="{DynamicResource Theme.Accent}"
                                           FontWeight="SemiBold"
                                           Margin="6,0,4,0"/>
                                <TextBlock Text="{x:Static resource:Strings.Options_Bytes}"
                                           Foreground="{DynamicResource Theme.Accent}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Border>
</TabItem>

            <!-- Tab: Popup Alerts -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Notifications}"
         Name="PopupAlertsTab"
         Style="{DynamicResource Style.SettingsTabItem}"
         Tag="{StaticResource geom.settings.notifications}">
    <Border Style="{DynamicResource Style.SettingsPagePanel}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Focusable="False"
                      FocusVisualStyle="{x:Null}">
            <Grid Margin="8,0,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{x:Static resource:Strings.Options_Tab_Notifications}"
                           Style="{StaticResource OptionHeaderTextStyle}"
                           Margin="4,0,4,14"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{DynamicResource Style.SettingsCard}">
                        <StackPanel>
                            <DockPanel LastChildFill="False"
                                       Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{x:Static resource:Strings.Options_Header_PopupAlerts}"
                                           Style="{DynamicResource Style.SettingsCardTitle}"
                                           Margin="0"/>
                                <Label DockPanel.Dock="Left"
                                       Style="{StaticResource LabelToolTip}">
                                    <TextBlock Text="{x:Static resource:Strings.Tooltip_PopupAlerts}"
                                               TextWrapping="Wrap"/>
                                </Label>
                            </DockPanel>

                            <RadioButton GroupName="PopupAlerts"
                                         Content="{x:Static resource:Strings.Options_Disabled}"
                                         Name="PopupsDisabledOption"
                                         Margin="0,4,0,4"/>
                            <RadioButton GroupName="PopupAlerts"
                                         Content="{x:Static resource:Strings.Options_ShowWhenMinimized}"
                                         Name="PopupsMinimizedOption"
                                         Margin="0,4,0,4"/>
                            <RadioButton GroupName="PopupAlerts"
                                         Content="{x:Static resource:Strings.Options_AlwaysShow}"
                                         Name="PopupsAlwaysOption"
                                         IsChecked="True"
                                         Margin="0,4,0,4"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{DynamicResource Style.SettingsCard}">
                        <StackPanel>
                            <DockPanel LastChildFill="False"
                                       Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{x:Static resource:Strings.Options_AutoDismiss}"
                                           Style="{DynamicResource Style.SettingsCardTitle}"
                                           Margin="0"/>
                                <Label DockPanel.Dock="Left"
                                       Style="{StaticResource LabelToolTip}"
                                       Content="{x:Static resource:Strings.Tooltip_AutoDismiss}"/>
                            </DockPanel>

                            <CheckBox Name="IsAutoDismissEnabled"
                                      Content="{x:Static resource:Strings.Options_AutoDismiss}"
                                      IsChecked="True"/>

                            <StackPanel Visibility="{Binding IsChecked, ElementName=IsAutoDismissEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Margin="28,12,0,0"
                                        Orientation="Horizontal">
                                <TextBox Name="AutoDismissInterval"
                                         PreviewTextInput="NumericTextbox_PreviewTextInput"
                                         Width="64"
                                         MaxLength="2"/>
                                <TextBlock Text="{x:Static resource:Strings.Options_Seconds}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Border>
</TabItem>

            <!-- Tab: Email Alerts -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Email}"
         Name="EmailAlertsTab"
         Style="{DynamicResource Style.SettingsTabItem}"
         Tag="{StaticResource geom.settings.email}">
    <Border Style="{DynamicResource Style.SettingsPagePanel}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Focusable="False"
                      FocusVisualStyle="{x:Null}">
            <Grid Margin="8,0,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{x:Static resource:Strings.Options_Header_EmailAlerts}"
                           Style="{StaticResource OptionHeaderTextStyle}"
                           Margin="4,0,4,14"/>

                <Border Grid.Row="1"
                        Style="{DynamicResource Style.SettingsCard}">
                    <DockPanel LastChildFill="False">
                        <CheckBox DockPanel.Dock="Left"
                                  Name="IsEmailAlertsEnabled"
                                  Click="IsEmailAlertsEnabled_Click"
                                  IsChecked="True"
                                  Content="{x:Static resource:Strings.Options_EnableEmailAlerts}"/>
                        <Label DockPanel.Dock="Left"
                               Style="{StaticResource LabelToolTip}"
                               Content="{x:Static resource:Strings.Tooltip_EnableEmailAlerts}"/>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="3"
                      Visibility="{Binding IsChecked, ElementName=IsEmailAlertsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{DynamicResource Style.SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_Header_ServerInfo}"
                                       Style="{DynamicResource Style.SettingsCardTitle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{x:Static resource:Strings.Options_SmtpServer}"
                                           VerticalAlignment="Center"
                                           Margin="0,4,10,4"/>
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Name="SmtpServer"
                                         Margin="0,4,0,4"/>

                                <TextBlock Grid.Row="1"
                                           Text="{x:Static resource:Strings.Options_Port}"
                                           VerticalAlignment="Center"
                                           Margin="0,4,10,4"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Name="SmtpPort"
                                         PreviewTextInput="NumericTextbox_PreviewTextInput"
                                         MaxLength="5"
                                         Width="76"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,4"/>

                                <CheckBox Grid.Row="2"
                                          Grid.Column="1"
                                          Name="IsSmtpSslEnabled"
                                          FontSize="13"
                                          Margin="0,6,0,4"
                                          Content="{x:Static resource:Strings.Options_EnableSSL}"/>
                            </Grid>

                            <CheckBox Name="IsSmtpAuthenticationRequired"
                                      Click="IsSmtpAuthenticationRequired_Click"
                                      Foreground="{DynamicResource Theme.Text.Secondary}"
                                      FontSize="13"
                                      Margin="0,8,0,4"
                                      Content="{x:Static resource:Strings.Options_SmtpAuth}"/>

                            <StackPanel Visibility="{Binding IsChecked, ElementName=IsSmtpAuthenticationRequired, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid Margin="0,4,0,0">
