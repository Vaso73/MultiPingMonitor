<Window x:Class="MultiPingMonitor.UI.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="{x:Static resource:Strings.Options_Title}"
        UseLayoutRounding="True"
        Height="540"
        Width="640"
        MinHeight="500"
        MinWidth="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#e1e1e1"
        SourceInitialized="Window_SourceInitialized">

    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#505050"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}" x:Key="OptionSubHeaderTextStyle">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="#268bd2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl TabStripPlacement="Left" HorizontalContentAlignment="Left">
            <!-- Tab: General -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_General}" Name="GeneralTab">
                <DockPanel Margin="20,0" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_Header_ProbeOptions}"
                               Style="{StaticResource OptionHeaderTextStyle}"/>
                    <!-- Ping interval -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_PingInterval}"
                                   Width="200"/>
                        <TextBox Name="PingInterval"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="60"
                                 MaxLength="5"/>
                        <ComboBox Name="PingIntervalUnits" Width="100" Margin="10,0,0,0">
                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Seconds}" IsSelected="True"/>
                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Minutes}"/>
                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Hours}"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Ping timeout -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_PingTimeout}"
                                   Width="200"/>
                        <TextBox Name="PingTimeout"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="60"
                                 MaxLength="2"/>
                        <TextBlock Text="{x:Static resource:Strings.Options_Seconds}"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <Separator DockPanel.Dock="Top" Height="1" Background="#ccc" Margin="0,20,0,5"/>

                    <!-- Alert threshold -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_AlertThreshold}"
                                   Width="155"/>
                        <TextBox Name="AlertThreshold"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="60"
                                 MaxLength="2"/>
                        <TextBlock Text="{x:Static resource:Strings.Options_DroppedPings}"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Latency detection separator -->
                    <Separator DockPanel.Dock="Top" Height="1" Background="#ccc" Margin="0,20,0,5"/>

                    <!-- Latency detection header -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_Header_LatencyDetection}"
                               Style="{StaticResource OptionSubHeaderTextStyle}"/>

                    <!-- Latency detection mode -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_DetectionMode}"
                                   Width="155"/>
                        <ComboBox Name="LatencyDetectionMode" Width="80">
                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Off}"/>
                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Auto}"/>
                            <ComboBoxItem Content="{x:Static resource:Strings.Options_Fixed}"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- High latency threshold -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_HighLatency}"
                                   Width="155"/>
                        <TextBox Name="HighLatencyMilliseconds"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="60"
                                 MaxLength="6"/>
                        <TextBlock Text="{x:Static resource:Strings.Options_Ms}"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- High latency trigger count -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_LatencyTriggers}"
                                   Width="155"/>
                        <TextBox Name="HighLatencyTriggerCount"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="60"
                                 MaxLength="3"/>
                        <TextBlock Text="{x:Static resource:Strings.Options_Probes}"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Startup header -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_Header_Startup}"
                               Margin="0,25,0,10"
                               Style="{StaticResource OptionHeaderTextStyle}"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_StartupPrompt}"
                               Margin="0,0,0,5"/>
                    <!-- Startup mode selection -->
                    <ComboBox DockPanel.Dock="Top"
                              Name="StartupMode"
                              Width="200">
                        <ComboBoxItem Content="{x:Static resource:Strings.Options_StartupBlank}" Tag="Standard" IsSelected="True"/>
                        <ComboBoxItem Content="{x:Static resource:Strings.Options_StartupListInput}" Tag="Standard"/>
                        <ComboBoxItem Content="{x:Static resource:Strings.Options_StartupFavorite}" Tag="Favorite"/>
                    </ComboBox>
                    <!-- Initial probe / column count -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,13,0,0">
                        <!-- Style to control visibility based on selected startup mode -->
                        <StackPanel.Style>
                            <Style>
                                <Setter Property="StackPanel.Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=StartupMode, Path=SelectedItem.Tag}" Value="Standard">
                                        <Setter Property="StackPanel.Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- Probe count -->
                        <StackPanel Margin="0,0,30,0">
                            <TextBlock Text="{x:Static resource:Strings.Options_ProbeCount}"
                                       Margin="0,0,0,4"/>
                            <TextBox Name="InitialProbeCount"
                                     PreviewTextInput="NumericTextbox_PreviewTextInput"
                                     Width="60"
                                     HorizontalAlignment="Left"
                                     MaxLength="2"/>
                        </StackPanel>
                        <!-- Column count-->
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_ColumnCount}"
                                       Margin="0,0,0,4"/>
                            <TextBox Name="InitialColumnCount"
                                     PreviewTextInput="NumericTextbox_PreviewTextInput"
                                     Width="60"
                                     HorizontalAlignment="Left"
                                     MaxLength="2"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Select a favorite -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,13,0,0">
                        <!-- Style to control visibility based on selected startup mode -->
                        <StackPanel.Style>
                            <Style>
                                <Setter Property="StackPanel.Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=StartupMode, Path=SelectedItem.Tag}" Value="Favorite">
                                        <Setter Property="StackPanel.Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- Favorite selection -->
                        <StackPanel Margin="0,0,35,0">
                            <TextBlock Text="{x:Static resource:Strings.Options_SelectFavorite}"
                                       Margin="0,0,0,4"/>
                            <ComboBox DockPanel.Dock="Top"
                                      Name="InitialFavorite"
                                      Width="250">
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </TabItem>

            <!-- Tab: Advanced -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Advanced}" Name="AdvancedTab">
                <DockPanel Margin="20,0" LastChildFill="False">

                    <!-- Header -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_Header_AdvancedICMP}"
                               Style="{StaticResource OptionHeaderTextStyle}"/>

                    <!-- TTL -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_TTL}"
                                   Width="135"/>
                        <TextBox Name="TTL"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="80"
                                 MaxLength="3"/>
                        <TextBlock Text="{x:Static resource:Strings.Options_Hops}"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Separator -->
                    <Separator DockPanel.Dock="Top" Height="1" Background="#ccc" Margin="0,20"/>

                    <!-- Packet size -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0">
                        <RadioButton GroupName="IcmpData"
                                     Content="{x:Static resource:Strings.Options_PacketDataSize}"
                                     Name="PacketSizeOption"
                                     Checked="PacketSizeOption_Checked"
                                     IsChecked="True"
                                     Width="160"/>
                        <TextBox Name="PacketSize"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 TextChanged="PacketData_TextChanged"
                                 Width="80"
                                 MaxLength="5"
                                 Visibility="{Binding IsChecked, ElementName=PacketSizeOption, Converter={StaticResource BooleanToHiddenVisibilityConverter}}"/>
                        <TextBlock Text="{x:Static resource:Strings.Options_Bytes}" Margin="10,0,0,0"
                                   Visibility="{Binding IsChecked, ElementName=PacketSizeOption, Converter={StaticResource BooleanToHiddenVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Packet data -->
                    <DockPanel DockPanel.Dock="Top"
                                Margin="0,7,0,0">
                        <RadioButton GroupName="IcmpData"
                                     Content="{x:Static resource:Strings.Options_CustomPacketData}"
                                     Name="UseCustomPacketOption"
                                     Checked="UseCustomPacketOption_Checked"
                                     DockPanel.Dock="Left"
                                     VerticalAlignment="Top"
                                     Width="160"/>
                        <TextBox Name="PacketData"
                                 TextChanged="PacketData_TextChanged"
                                 Height="80"
                                 DockPanel.Dock="Right"
                                 VerticalContentAlignment="Top"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MaxLength="65500"
                                 Visibility="{Binding IsChecked, ElementName=UseCustomPacketOption, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </DockPanel>

                    <!-- Total packet size -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,15,0,0">
                        <TextBlock Foreground="#0e70c0"
                                   Text="{x:Static resource:Strings.Options_TotalPacketSize}"/>
                        <TextBlock Foreground="#dc322f"
                                   Name="Bytes"
                                   Margin="6,0,4,0"
                                   Text="64"/>
                        <TextBlock Foreground="#dc322f"
                                   Text="{x:Static resource:Strings.Options_Bytes}"/>
                    </StackPanel>

                    <!-- Separator -->
                    <Separator DockPanel.Dock="Top" Height="1" Background="#ccc" Margin="0,20"/>

                    <!-- Fragment / Don't fragment -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                        <CheckBox DockPanel.Dock="Left"
                                  Name="DontFragment"
                                  Content="{x:Static resource:Strings.Options_DontFragment}"/>
                        <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}">
                            <TextBlock Text="{x:Static resource:Strings.Tooltip_DontFragment}" TextWrapping="Wrap"/>
                        </Label>
                    </DockPanel>
                </DockPanel>
            </TabItem>
            
            <!-- Tab: Popup Alerts -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Notifications}" Name="PopupAlertsTab">
                <DockPanel Margin="20,0" LastChildFill="False">

                    <!-- Header -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{x:Static resource:Strings.Options_Header_PopupAlerts}"
                                   Style="{StaticResource OptionHeaderTextStyle}"/>
                        <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}">
                            <TextBlock Text="{x:Static resource:Strings.Tooltip_PopupAlerts}" TextWrapping="Wrap"/>
                        </Label>
                    </DockPanel>


                    <!-- Popup notification option radio button group -->
                    <RadioButton DockPanel.Dock="Top"
                                 GroupName="PopupAlerts"
                                 Content="{x:Static resource:Strings.Options_Disabled}"
                                 Name="PopupsDisabledOption"
                                 Margin="0,15,0,0"/>
                    <RadioButton DockPanel.Dock="Top"
                                 GroupName="PopupAlerts"
                                 Content="{x:Static resource:Strings.Options_ShowWhenMinimized}"
                                 Name="PopupsMinimizedOption"
                                 Margin="0,6"/>
                    <RadioButton DockPanel.Dock="Top"
                                 GroupName="PopupAlerts"
                                 Content="{x:Static resource:Strings.Options_AlwaysShow}"
                                 Name="PopupsAlwaysOption"
                                 IsChecked="True"/>

                    <!-- Auto-dismiss enabled checkbox -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,20,0,5">
                        <CheckBox DockPanel.Dock="Left"
                                  Name="IsAutoDismissEnabled"
                                  Content="{x:Static resource:Strings.Options_AutoDismiss}"
                                  IsChecked="True"/>
                        <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}"
                               Content="{x:Static resource:Strings.Tooltip_AutoDismiss}"/>
                    </DockPanel>

                    <!-- Auto-dismiss interval textbox -->
                    <StackPanel DockPanel.Dock="Top"
                                Visibility="{Binding IsChecked, ElementName=IsAutoDismissEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Margin="50,0,0,0"
                                Orientation="Horizontal">
                        <TextBox Name="AutoDismissInterval"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="60"
                                 MaxLength="2"/>
                        <TextBlock Text="{x:Static resource:Strings.Options_Seconds}"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </DockPanel>
            </TabItem>

            <!-- Tab: Email Alerts -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Email}" Name="EmailAlertsTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <DockPanel Margin="20,0,20,15">

                        <!-- Header -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{x:Static resource:Strings.Options_Header_EmailAlerts}"
                                   Style="{StaticResource OptionHeaderTextStyle}"/>

                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,15,0,15">
                            <CheckBox DockPanel.Dock="Top"
                                      Name="IsEmailAlertsEnabled"
                                      Content="{x:Static resource:Strings.Options_EnableEmailAlerts}"
                                      Click="IsEmailAlertsEnabled_Click"
                                      IsChecked="True"/>
                            <Label Style="{StaticResource LabelToolTip}"
                                   Content="{x:Static resource:Strings.Tooltip_EnableEmailAlerts}"/>
                        </StackPanel>

                        <DockPanel LastChildFill="False"
                                   DockPanel.Dock="Top"
                                   Margin="0"
                                   Visibility="{Binding IsChecked, ElementName=IsEmailAlertsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DockPanel.Resources>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,12,0"/>
                                </Style>
                                <Style TargetType="{x:Type DockPanel}">
                                    <Setter Property="Margin" Value="0,3,0,3"/>
                                    <Setter Property="DockPanel.Dock" Value="Top"/>
                                </Style>
                            </DockPanel.Resources>

                            <!-- Server information subheading -->
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{x:Static resource:Strings.Options_Header_ServerInfo}"
                                       Style="{StaticResource OptionSubHeaderTextStyle}"/>

                            <!-- SMTP Server-->
                            <DockPanel>
                                <Grid Width="165">
                                    <TextBlock Text="{x:Static resource:Strings.Options_SmtpServer}"/>
                                </Grid>
                                <TextBox Name="SmtpServer"/>
                            </DockPanel>

                            <!-- Smtp Port -->
                            <DockPanel>
                                <Grid Width="165">
                                    <TextBlock Text="{x:Static resource:Strings.Options_Port}"/>
                                </Grid>
                                <TextBox Name="SmtpPort"
                                         PreviewTextInput="NumericTextbox_PreviewTextInput"
                                         HorizontalAlignment="Left"
                                         MaxLength="5"
                                         Width="75"/>
                                <CheckBox Name="IsSmtpSslEnabled"
                                          Content="{x:Static resource:Strings.Options_EnableSSL}"
                                          FontSize="13"
                                          Margin="50,0,0,0"/>
                            </DockPanel>

                            <!-- Authentication section -->
                            <!-- Smtp Authentication -->
                            <CheckBox DockPanel.Dock="Top"
                                      Name="IsSmtpAuthenticationRequired"
                                      Content="{x:Static resource:Strings.Options_SmtpAuth}"
                                      Click="IsSmtpAuthenticationRequired_Click"
                                      Foreground="#888"
                                      FontSize="13"
                                      Margin="165,8,0,0"/>
                            <StackPanel DockPanel.Dock="Top"
                                        Visibility="{Binding IsChecked, ElementName=IsSmtpAuthenticationRequired, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!-- Smtp User -->
                                <DockPanel>
                                    <Grid Width="165">
                                        <TextBlock Text="{x:Static resource:Strings.Options_Username}"/>
                                    </Grid>
                                    <TextBox Name="SmtpUsername"/>
                                </DockPanel>

                                <!-- Smtp Password -->
                                <DockPanel>
                                    <Grid Width="165">
                                        <TextBlock Text="{x:Static resource:Strings.Options_Password}"/>
                                    </Grid>
                                    <PasswordBox Name="SmtpPassword"/>
                                </DockPanel>
                            </StackPanel>

                            <!-- Email addresses subheading -->
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{x:Static resource:Strings.Options_Header_EmailAddresses}"
                                       Margin="0,12,0,5"
                                       Style="{StaticResource OptionSubHeaderTextStyle}"/>

                            <!-- Recipient Address-->
                            <DockPanel>
                                <Grid Width="165">
                                    <TextBlock Text="{x:Static resource:Strings.Options_RecipientAddress}"/>
                                </Grid>
                                <TextBox Name="EmailRecipientAddress"
                                         LostFocus="EmailRecipientAddress_LostFocus"/>
                            </DockPanel>

                            <!-- From Address-->
                            <DockPanel>
                                <Grid Width="165">
                                    <TextBlock Text="{x:Static resource:Strings.Options_FromAddress}"/>
                                </Grid>
                                <TextBox Name="EmailFromAddress"/>
                            </DockPanel>

                            <!-- Test button -->
                            <Button Style="{StaticResource ButtonStandardStyle}"
                                    Name="TestEmailButton"
                                    Visibility="{Binding IsChecked, ElementName=IsEmailAlertsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    DockPanel.Dock="Top"
                                    Click="TestEmail_Click"
                                    Width="85"
                                    Margin="0,18,0,0"
                                    Content="{x:Static resource:Strings.Options_Test}"
                                    HorizontalAlignment="Left"/>
                        </DockPanel>
                    </DockPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: Audio Alerts -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Sounds}" Name="AudioAlertTab">
                <DockPanel Margin="20,0">

                    <!-- Header -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_Header_AudioAlerts}"
                               Style="{StaticResource OptionHeaderTextStyle}"/>

                    <!-- Audio Alert Down: checkbox / tooltip -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,15,0,0">
                        <CheckBox Name="IsAudioDownAlertEnabled"
                                  Click="IsAudioDownAlertEnabled_Click"
                                  Content="{x:Static resource:Strings.Options_EnableAudioDown}"
                                  IsChecked="True"/>
                        <Label Style="{StaticResource LabelToolTip}"
                               Content="{x:Static resource:Strings.Tooltip_AudioDown}"/>
                    </StackPanel>

                    <!-- Audio Alert Down: Filepath / play button / browse button -->
                    <Grid DockPanel.Dock="Top"
                          Margin="30,10,0,0"
                          VerticalAlignment="Top"
                          Visibility="{Binding IsChecked, ElementName=IsAudioDownAlertEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_AudioFilePath}"/>
                            <TextBox Name="AudioDownFilePath"
                                     Margin="0,4,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <!-- Browse button -->
                                <Button Style="{StaticResource ButtonStandardStyle}"
                                        Click="AudioDownBrowse_Click"
                                        Width="85"
                                        Content="{x:Static resource:Strings.Options_Browse}"/>
                                <!-- Play button -->
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=AudioDownFilePath}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Button Style="{StaticResource ButtonStandardStyle}"
                                            Click="AudioDownPlay_Click"
                                            Width="85"
                                            Margin="10,0,0,0"
                                            Content="{x:Static resource:Strings.Options_Test}">
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Hidden separator -->
                    <Separator DockPanel.Dock="Top" Height="1" Background="Transparent" Margin="0,20,0,0"
                               Visibility="{Binding IsChecked, ElementName=IsAudioDownAlertEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Audio Alert Up: checkbox / tooltip -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,15,0,0">
                        <CheckBox Name="IsAudioUpAlertEnabled"
                                  Click="IsAudioUpAlertEnabled_Click"
                                  Content="{x:Static resource:Strings.Options_EnableAudioUp}"
                                  IsChecked="True"/>
                        <Label Style="{StaticResource LabelToolTip}"
                               Content="{x:Static resource:Strings.Tooltip_AudioUp}"/>
                    </StackPanel>

                    <!-- Audio Alert Down: Filepath / play button / browse button -->
                    <Grid DockPanel.Dock="Top"
                          Margin="30,10,0,0"
                          VerticalAlignment="Top"
                          Visibility="{Binding IsChecked, ElementName=IsAudioUpAlertEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_AudioFilePath}"/>
                            <TextBox Name="AudioUpFilePath"
                                     Margin="0,4,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <!-- Browse button -->
                                <Button Style="{StaticResource ButtonStandardStyle}"
                                        Click="AudioUpBrowse_Click"
                                        Width="85"
                                        Content="{x:Static resource:Strings.Options_Browse}"/>
                                <!-- Play button -->
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=AudioUpFilePath}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Button Style="{StaticResource ButtonStandardStyle}"
                                            Click="AudioUpPlay_Click"
                                            Width="85"
                                            Margin="10,0,0,0"
                                            Content="{x:Static resource:Strings.Options_Test}">
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Tab: Logging -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Logging}" Name="LogOutputTab">
                <DockPanel Margin="20,0">

                    <!-- Header -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_Header_LogOutput}"
                               Style="{StaticResource OptionHeaderTextStyle}"/>

                    <!-- Log all ping output -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,15,0,0">
                        <CheckBox Name="IsLogOutputEnabled"
                                  Content="{x:Static resource:Strings.Options_WritePingOutput}"
                                  IsChecked="True"/>
                        <Label Style="{StaticResource LabelToolTip}">
                            <TextBlock Text="{x:Static resource:Strings.Tooltip_LogOutput}" TextWrapping="Wrap"/>
                        </Label>
                    </StackPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="30,10,0,0"
                          VerticalAlignment="Top"
                          Visibility="{Binding IsChecked, ElementName=IsLogOutputEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_LogPath}"/>
                            <TextBox Name="LogPath"
                                     Margin="0,4,0,8"/>
                            <Button Style="{StaticResource ButtonStandardStyle}"
                                    Click="BrowseLogPath_Click"
                                    Width="85"
                                    Content="{x:Static resource:Strings.Options_Browse}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>

                    <!-- Hidden separator -->
                    <Separator DockPanel.Dock="Top" Height="1" Background="Transparent" Margin="0,20,0,0"
                               Visibility="{Binding IsChecked, ElementName=IsLogOutputEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Log status changes -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,15,0,0">
                        <CheckBox Name="IsLogStatusChangesEnabled"
                                  Content="{x:Static resource:Strings.Options_LogStatusChanges}"
                                  IsChecked="True"/>
                        <Label Style="{StaticResource LabelToolTip}">
                            <TextBlock Text="{x:Static resource:Strings.Tooltip_LogStatusChanges}" TextWrapping="Wrap"/>
                        </Label>
                    </StackPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="30,10,0,0"
                          VerticalAlignment="Top"
                          Visibility="{Binding IsChecked, ElementName=IsLogStatusChangesEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resource:Strings.Options_LogPathSimple}"/>
                            <TextBox Name="LogStatusChangesPath"
                                     Margin="0,4,0,8"/>
                            <Button Style="{StaticResource ButtonStandardStyle}"
                                    Click="BrowseLogStatusChangesPath_Click"
                                    Width="85"
                                    Content="{x:Static resource:Strings.Options_Browse}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Tab: Display -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Display}" Name="DisplayTab">
                <DockPanel Margin="20,0" LastChildFill="False">

                    <!-- Header -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_Header_DisplayOptions}"
                               Style="{StaticResource OptionHeaderTextStyle}"/>

                    <!-- Always on top -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,15,0,0">
                        <CheckBox DockPanel.Dock="Left"
                                  Name="IsAlwaysOnTopEnabled"
                                  Content="{x:Static resource:Strings.Options_AlwaysOnTop}"/>
                        <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}"
                               Content="{x:Static resource:Strings.Tooltip_AlwaysOnTop}"/>
                    </DockPanel>
                    <!-- Minimze to tray -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,15,0,0">
                        <CheckBox DockPanel.Dock="Left"
                                  Name="IsMinimizeToTrayEnabled"
                                  Content="{x:Static resource:Strings.Options_MinimizeToTray}"/>
                        <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}">
                            <TextBlock Text="{x:Static resource:Strings.Tooltip_MinimizeToTray}" TextWrapping="Wrap"/>
                        </Label>
                    </DockPanel>
                    <!-- Exit to tray -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,15,0,0">
                        <CheckBox DockPanel.Dock="Left"
                                  Name="IsExitToTrayEnabled"
                                  Content="{x:Static resource:Strings.Options_ExitToTray}"/>
                        <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}">
                            <TextBlock Text="{x:Static resource:Strings.Tooltip_ExitToTray}" TextWrapping="Wrap"/>
                        </Label>
                    </DockPanel>
                    <!-- Start in tray -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,15,0,0">
                        <CheckBox DockPanel.Dock="Left"
                                  Name="StartInTray"
                                  Content="{x:Static resource:Strings.Options_StartInTray}"/>
                        <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}">
                            <TextBlock Text="{x:Static resource:Strings.Tooltip_StartInTray}" TextWrapping="Wrap"/>
                        </Label>
                    </DockPanel>
                    <!-- Remember window position -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,15,0,0">
                        <CheckBox DockPanel.Dock="Left"
                                  Name="RememberWindowPosition"
                                  Content="{x:Static resource:Strings.Options_RememberWindowPosition}"/>
                        <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}"
                               Content="{x:Static resource:Strings.Tooltip_RememberWindowPosition}"/>
                    </DockPanel>
                    <!-- Theme selection -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_Theme}" Width="120"/>
                        <ComboBox x:Name="ThemeComboBox" Width="160" SelectionChanged="ThemeComboBox_SelectionChanged"/>
                    </StackPanel>
                    <!-- Language selection -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_Language}" Width="120"/>
                        <ComboBox x:Name="LanguageComboBox" Width="160"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_LanguageRestart}"
                               Foreground="#888" FontSize="12" Margin="122,3,0,0"/>

                    <Separator DockPanel.Dock="Top" Height="1" Background="#ccc" Margin="0,20,0,5"/>

                    <!-- Font Sizes -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static resource:Strings.Options_Header_FontSizes}"
                               Margin="0,10,0,0"
                               Style="{StaticResource OptionSubHeaderTextStyle}"/>
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_ProbeFontSize}"
                                   Width="200"/>
                        <TextBox Name="FontSizeProbe"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="60"
                                 MaxLength="2"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="{x:Static resource:Strings.Options_ScannerFontSize}"
                                   Width="200"/>
                        <TextBox Name="FontSizeScanner"
                                 PreviewTextInput="NumericTextbox_PreviewTextInput"
                                 Width="60"
                                 MaxLength="2"/>
                    </StackPanel>
                </DockPanel>
            </TabItem>
            
            <!-- Tab: Layout -->
            <TabItem Header="{x:Static resource:Strings.Options_Tab_Colors}" Name="LayoutTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <DockPanel LastChildFill="False"
                               Name="ColorsDockPanel"
                               Margin="20,0,20,20">
                        <DockPanel.Resources>
                            <Style TargetType="{x:Type StackPanel}">
                                <Setter Property="Orientation" Value="Horizontal"/>
                                <Setter Property="Margin" Value="0,5,0,0"/>
                                <Setter Property="DockPanel.Dock" Value="Top"/>
                            </Style>
                            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource HtmlTextBoxStyle}">
                                <EventSetter Event="PreviewTextInput" Handler="HtmlColor_PreviewTextInput"/>
                            </Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="BorderBrush" Value="Black"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Width" Value="80"/>
                                <Setter Property="Margin" Value="15,0,0,0"/>
                            </Style>
                        </DockPanel.Resources>

                        <!-- Header -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{x:Static resource:Strings.Options_Header_Colors}"
                                   Style="{StaticResource OptionHeaderTextStyle}"/>

                        <!-- Probe background colors -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{x:Static resource:Strings.Options_Header_ProbeBackground}"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource OptionSubHeaderTextStyle}"/>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Inactive}"/>
                            <TextBox Name="BackgroundColor_Probe_Inactive"/>
                            <Border Background="{Binding ElementName=BackgroundColor_Probe_Inactive, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Up}"/>
                            <TextBox Name="BackgroundColor_Probe_Up"/>
                            <Border Background="{Binding ElementName=BackgroundColor_Probe_Up, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Down}"/>
                            <TextBox Name="BackgroundColor_Probe_Down"/>
                            <Border Background="{Binding ElementName=BackgroundColor_Probe_Down, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Indeterminate}"/>
                            <TextBox Name="BackgroundColor_Probe_Indeterminate"/>
                            <Border Background="{Binding ElementName=BackgroundColor_Probe_Indeterminate, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Error}"/>
                            <TextBox Name="BackgroundColor_Probe_Error"/>
                            <Border Background="{Binding ElementName=BackgroundColor_Probe_Error, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>

                        <!-- Probe foreground colors -->
                        <Separator DockPanel.Dock="Top" Height="1" Width="20" Background="Transparent" Margin="0,20,0,0"/>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{x:Static resource:Strings.Options_Header_ProbeForeground}"
                                   Margin="0"
                                   Style="{StaticResource OptionSubHeaderTextStyle}"/>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Inactive}"/>
                            <TextBox Name="ForegroundColor_Probe_Inactive"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Probe_Inactive, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Up}"/>
                            <TextBox Name="ForegroundColor_Probe_Up"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Probe_Up, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Down}"/>
                            <TextBox Name="ForegroundColor_Probe_Down"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Probe_Down, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Indeterminate}"/>
                            <TextBox Name="ForegroundColor_Probe_Indeterminate"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Probe_Indeterminate, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Error}"/>
                            <TextBox Name="ForegroundColor_Probe_Error"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Probe_Error, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>

                        <!-- Statistics foreground colors -->
                        <Separator DockPanel.Dock="Top" Height="1" Width="20" Background="Transparent" Margin="0,20,0,0"/>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{x:Static resource:Strings.Options_Header_StatsForeground}"
                                   Margin="0"
                                   Style="{StaticResource OptionSubHeaderTextStyle}"/>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Inactive}"/>
                            <TextBox Name="ForegroundColor_Stats_Inactive"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Stats_Inactive, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Up}"/>
                            <TextBox Name="ForegroundColor_Stats_Up"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Stats_Up, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Down}"/>
                            <TextBox Name="ForegroundColor_Stats_Down"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Stats_Down, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Indeterminate}"/>
                            <TextBox Name="ForegroundColor_Stats_Indeterminate"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Stats_Indeterminate, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,10">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Error}"/>
                            <TextBox Name="ForegroundColor_Stats_Error"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Stats_Error, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>

                        <!-- Alias foreground colors -->
                        <Separator DockPanel.Dock="Top" Height="1" Width="20" Background="Transparent" Margin="0,20,0,0"/>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{x:Static resource:Strings.Options_Header_AliasForeground}"
                                   Margin="0"
                                   Style="{StaticResource OptionSubHeaderTextStyle}"/>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Inactive}"/>
                            <TextBox Name="ForegroundColor_Alias_Inactive"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Alias_Inactive, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Up}"/>
                            <TextBox Name="ForegroundColor_Alias_Up"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Alias_Up, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Down}"/>
                            <TextBox Name="ForegroundColor_Alias_Down"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Alias_Down, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Indeterminate}"/>
                            <TextBox Name="ForegroundColor_Alias_Indeterminate"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Alias_Indeterminate, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,10">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_Error}"/>
                            <TextBox Name="ForegroundColor_Alias_Error"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Alias_Error, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>

                        <!-- Scanner colors -->
                        <Separator DockPanel.Dock="Top" Height="1" Width="20" Background="Transparent" Margin="0,20,0,0"/>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{x:Static resource:Strings.Options_Header_Scanner}"
                                   Margin="0"
                                   Style="{StaticResource OptionSubHeaderTextStyle}"/>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_ProbeBackground}"/>
                            <TextBox Name="BackgroundColor_Probe_Scanner"/>
                            <Border Background="{Binding ElementName=BackgroundColor_Probe_Scanner, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_ProbeForeground}"/>
                            <TextBox Name="ForegroundColor_Probe_Scanner"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Probe_Scanner, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,5,0,10">
                            <TextBlock Width="150" Text="{x:Static resource:Strings.Options_Color_AliasForeground}"/>
                            <TextBox Name="ForegroundColor_Alias_Scanner"/>
                            <Border Background="{Binding ElementName=ForegroundColor_Alias_Scanner, Path=Text, Converter={StaticResource StringToBrushConverter}}"/>
                        </StackPanel>

                        <!-- Restore defaults button -->
                        <Grid DockPanel.Dock="Top" Margin="0,15,0,0">
                            <Button Style="{StaticResource ButtonStandardStyle}"
                                    Click="RestoreDefaultColors_Click"
                                    Padding="15,5"
                                    Content="{x:Static resource:Strings.Options_RestoreDefaults}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </DockPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>


        <!-- Button Section -->
        <Border Grid.Row="1" BorderBrush="#dfdfdf" Background="#f0f0f0" BorderThickness="0,1,0,0">
            <DockPanel Margin="9" HorizontalAlignment="Right">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,9,0,0" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ButtonStandardStyle}"
                            Click="OK_Click"
                            Margin="0,0,9,0"
                            IsDefault="True"
                            Width="85"
                            Content="{x:Static resource:Strings.DialogButton_OK}"/>
                    <Button Style="{StaticResource ButtonStandardStyle}"
                            IsCancel="True"
                            Width="85"
                            Content="{x:Static resource:Strings.DialogButton_Cancel}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
