<Window x:Class="MultiPingMonitor.UI.NewFavoriteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="{x:Static resource:Strings.NewFavorite_WindowTitle}"
        UseLayoutRounding="True"
        WindowStyle="None"
        Height="450"
        Width="450"
        MinHeight="350"
        MinWidth="300"
        ResizeMode="CanResize"
        Background="{DynamicResource Theme.Background}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource WindowMainPanelStyle}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="16" Height="16" Margin="8,0,4,0"
                   Source="{StaticResource icon.new-favorite}" x:Name="TitleBarIcon" />
            <TextBlock Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13"
                       Foreground="{DynamicResource Theme.Text.Primary}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button Grid.Column="2" Click="OnCloseButtonClick"
                    Style="{StaticResource TitleBarCloseButtonStyle}" AutomationProperties.Name="Close"
                    ToolTip="Close" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Theme.Border}" />

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="9">
            <!-- Header -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                <Image Name="HeaderIcon"
                       Source="{StaticResource icon.new-favorite}"
                       VerticalAlignment="Center"
                       Width="20"
                       Height="20"
                       Margin="0,0,8,0"/>
                <TextBlock DockPanel.Dock="Top"
                           Name="Header"
                           Text="{x:Static resource:Strings.NewFavorite_Header}"
                           Style="{StaticResource ResourceKey=OptionHeaderTextStyle}"/>
            </StackPanel>

            <!-- Title / Columns section -->
            <Grid DockPanel.Dock="Top" Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Title -->
                <StackPanel>
                    <TextBlock Text="{x:Static resource:Strings.NewFavorite_Title}"
                               Foreground="{DynamicResource Theme.Text.Secondary}"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBox Name="MyTitle"
                             Margin="0,4,0,0"
                             MaxLength="64"/>
                </StackPanel>

                <!-- Columns -->
                <StackPanel Grid.Column="1" Width="80" Margin="20,0,0,0">
                    <TextBlock Text="{x:Static resource:Strings.NewFavorite_Columns}"
                               Foreground="{DynamicResource Theme.Text.Secondary}"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBox DockPanel.Dock="Top"
                             Name="MyColumnCount"
                             Margin="0,4,0,0"
                             MaxLength="2"
                             PreviewTextInput="MyColumnCount_PreviewTextInput"/>
                </StackPanel>
            </Grid>


            <!-- Section for hosts that will be added to favorite -->
            <DockPanel DockPanel.Dock="Top" Margin="0,10" Name="ContentsSection">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,15,0,0">
                    <TextBlock Text="{x:Static resource:Strings.NewFavorite_HostsHeader}"
                               Foreground="{DynamicResource Theme.Text.Secondary}"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <Label Style="{StaticResource LabelToolTip}" MaxWidth="380">
                        <TextBlock>
                            Type a list of addresses to include in this favorite set.<LineBreak/>
                            Enter either one per line or comma separated.<LineBreak/><LineBreak/>
                            If you have a text file containing hosts, drag and drop it here.
                        </TextBlock>
                    </Label>
                </StackPanel>

                <!-- Multiline input for hosts -->
                <TextBox x:Name="MyHosts"
                         FontFamily="Consolas"
                         FontSize="15"
                         Height="Auto"
                         Margin="0,3,0,0"
                         Padding="4"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         AllowDrop="True"
                         PreviewDragOver="MyHosts_PreviewDragOver"
                         Drop="MyHosts_Drop"/>
            </DockPanel>
        </DockPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="9,0,9,9">
            <Button Style="{StaticResource ButtonStandardStyle}"
                    IsDefault="True"
                    Margin="0,0,9,0"
                    Click="Save_Click"
                    Width="85"
                    Content="{x:Static resource:Strings.DialogButton_Save}" />
            <Button Style="{StaticResource ButtonStandardStyle}"
                    Width="85"
                    IsCancel="True"
                    Content="{x:Static resource:Strings.DialogButton_Cancel}" />
        </StackPanel>
    </Grid>
    </DockPanel>
    </Border>
</Window>
