<Window x:Class="MultiPingMonitor.UI.ManageCompactTargetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        mc:Ignorable="d"
        Title="{x:Static resource:Strings.CompactTargets_Title}"
        UseLayoutRounding="True"
        WindowStyle="None"
        Height="450" MinHeight="250"
        Width="380" MinWidth="280"
        Background="{DynamicResource Theme.Background}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="16" Height="16" Margin="8,0,4,0"
                   Source="{StaticResource icon.compact-view}" />
            <TextBlock Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13"
                       Foreground="{DynamicResource Theme.Text.Primary}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button Grid.Column="2" Click="OnCloseButtonClick"
                    Style="{DynamicResource Style.TitleBarCloseButton}" AutomationProperties.Name="Close"
                    ToolTip="Close" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Theme.Border}" />

    <Grid Margin="9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel LastChildFill="False">
            <Image DockPanel.Dock="Left" Source="{StaticResource icon.compact-view}" VerticalAlignment="Center" Width="20" Height="20" Margin="0,0,8,0"/>
            <TextBlock DockPanel.Dock="Left"
                       Text="{x:Static resource:Strings.CompactTargets_Header}"
                       Style="{StaticResource OptionHeaderTextStyle}" />
            <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}" MaxWidth="280">
                <TextBlock Text="{x:Static resource:Strings.CompactTargets_Tooltip}" TextWrapping="Wrap"/>
            </Label>
        </DockPanel>

        <!-- Input -->
        <TextBox x:Name="TargetsTextBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top"
                 FontFamily="Consolas"
                 FontSize="14"
                 Padding="5"
                 AllowDrop="True"
                 PreviewDragOver="TargetsTextBox_PreviewDragOver"
                 Drop="TargetsTextBox_Drop"/>

        <!-- Buttons section -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,9,0,0">
            <Button Style="{DynamicResource Style.ButtonStandard}"
                    Content="OK"
                    Width="85"
                    Click="OK_Click"/>
            <Button Style="{DynamicResource Style.ButtonStandard}"
                    Content="Cancel"
                    Width="85"
                    Margin="9,0,0,0"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
    </DockPanel>
    </Border>
</Window>
