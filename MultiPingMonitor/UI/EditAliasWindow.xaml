<Window x:Class="MultiPingMonitor.UI.EditAliasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        mc:Ignorable="d"
        Title="{x:Static resource:Strings.EditAlias_WindowTitle}"
        UseLayoutRounding="True"
        WindowStyle="None"
        Height="Auto"
        Width="400"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme.Background}"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="16" Height="16" Margin="8,0,4,0"
                   Source="{StaticResource icon.edit}" />
            <TextBlock Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13"
                       Foreground="{DynamicResource Theme.Text.Primary}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button Grid.Column="2" Click="OnCloseButtonClick"
                    Style="{DynamicResource Style.TitleBarCloseButton}" AutomationProperties.Name="Close"
                    ToolTip="Close" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Theme.Border}" />

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   LastChildFill="False"
                   Margin="9">
            <!-- Header -->
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Top">
                <Image Source="{StaticResource icon.edit}"
                       VerticalAlignment="Center"
                       Width="20"
                       Height="20"
                       Margin="0,0,8,0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static resource:Strings.EditAlias_Header}"
                               Style="{StaticResource ResourceKey=OptionHeaderTextStyle}"/>
                    <TextBlock x:Name="Hostname"
                               d:Text="hostname"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource ResourceKey=OptionHeaderTextStyle}"/>
                </StackPanel>
            </StackPanel>

            <!-- Alias TextBox-->
            <TextBox x:Name="NewAlias"
                     DockPanel.Dock="Top"
                     Margin="0,0,0,10"
                     MaxLength="64"/>
        </DockPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="9,0,9,9">
            <Button Style="{DynamicResource Style.ButtonStandard}"
                    IsDefault="True"
                    Margin="0,0,9,0"
                    Click="Save_Click"
                    Width="85"
                    Content="{x:Static resource:Strings.DialogButton_Save}" />
            <Button Style="{DynamicResource Style.ButtonStandard}"
                    Width="85"
                    IsCancel="True"
                    Content="{x:Static resource:Strings.DialogButton_Cancel}" />
        </StackPanel>
    </Grid>
    </DockPanel>
    </Border>
</Window>
