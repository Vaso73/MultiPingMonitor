<Window x:Class="MultiPingMonitor.UI.UsageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MultiPingMonitor.UI"
        mc:Ignorable="d"
        Title="MultiPingMonitor"
        Width="600"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="{StaticResource Theme.Background}"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="20,10,20,35">
            <StackPanel.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style>
                <Style TargetType="{x:Type TextBlock}" x:Key="Arg" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="Width" Value="130"/>
                    <Setter Property="DockPanel.Dock" Value="Left"/>
                </Style>
                <Style TargetType="{x:Type TextBlock}" x:Key="Desc" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="Foreground" Value="#223"/>
                </Style>
            </StackPanel.Resources>
            <StackPanel Orientation="Horizontal">
                <Image Source="/MultiPingMonitor.ico"
                       VerticalAlignment="Top"
                       Width="32"
                       Height="32"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="MultiPingMonitor"
                               Foreground="#000000"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontFamily="Arial"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="AppVersion"
                               d:Text="1.0.0"
                               FontSize="13"
                               Opacity="0.5"/>
                </StackPanel>
            </StackPanel>
            <TextBlock x:Name="CommandLineUsageHeader"
                       Margin="0,20,0,0"
                       Text="Command line usage:"
                       FontSize="14"
                       FontWeight="SemiBold"/>
            <TextBlock Text="MultiPingMonitor [OPTIONS] [HOSTNAME...] [FILE...]"/>
            <TextBlock x:Name="OptionsHeader"
                       Margin="0,20,0,0"
                       Text="Options:"
                       FontSize="14"
                       FontWeight="SemiBold"/>
            <DockPanel>
                <TextBlock Style="{StaticResource Arg}"
                           Text="-i &lt;interval>"/>
                <StackPanel>
                    <TextBlock x:Name="IntervalDescriptionText"
                               Style="{StaticResource Desc}"
                               Text="Specifies the interval, in seconds, between pings."/>
                    <TextBlock x:Name="IntervalRangeText"
                               Style="{StaticResource Desc}"
                               Text="Valid range: 1 to 86400 (1 second to 24 hours)."/>
                </StackPanel>
            </DockPanel>
            <DockPanel Margin="0,5,0,0">
                <TextBlock Style="{StaticResource Arg}"
                           Text="-w &lt;timeout>"/>
                <StackPanel>
                    <TextBlock x:Name="TimeoutDescriptionText"
                               Style="{StaticResource Desc}"
                               Text="Set the timeout, in seconds, for each ping request."/>
                    <TextBlock x:Name="TimeoutRangeText"
                               Style="{StaticResource Desc}"
                               Text="Valid range: 1 to 60 seconds."/>
                </StackPanel>
            </DockPanel>
            <DockPanel Margin="0,5,0,0">
                <TextBlock Style="{StaticResource Arg}"
                           Text="-minimized"/>
                <TextBlock x:Name="StartMinimizedDescriptionText"
                           Style="{StaticResource Desc}"
                           Text=""/>
            </DockPanel>
            <DockPanel Margin="0,5,0,0">
                <TextBlock Style="{StaticResource Arg}"
                           Text="&lt;hostname>"/>
                <StackPanel>
                    <TextBlock x:Name="HostnameDescriptionText"
                               Style="{StaticResource Desc}"
                               Text="A hostname or IP address to ping."/>
                    <TextBlock x:Name="MultipleHostnamesDescriptionText"
                               Style="{StaticResource Desc}"
                               Text="You can provide multiple hostnames."/>
                </StackPanel>
            </DockPanel>
            <DockPanel Margin="0,5,0,0">
                <TextBlock Style="{StaticResource Arg}"
                           Text="&lt;file>"/>
                <TextBlock x:Name="FileDescriptionText"
                           Style="{StaticResource Desc}"
                           Text="The path to a text file containing hostnames or IP addresses to ping. Wrap the path in quotes if it contains spaces. You can provide multiple files."/>
            </DockPanel>
            <TextBlock x:Name="ExamplesHeader"
                       Margin="0,20,0,0"
                       Text="Examples:"
                       FontSize="14"
                       FontWeight="SemiBold"/>
            <TextBlock Text="MultiPingMonitor.exe -i 5 -w 2 192.168.0.1 172.16.50.1 10.2.0.32"/>
            <TextBlock Text="MultiPingMonitor.exe &quot;c:\documents\servers.txt&quot;"/>
            <TextBlock Text="MultiPingMonitor.exe -minimized 192.168.5.20 web.example.com"/>

        </StackPanel>

        <!-- Buttons -->
        <Border Grid.Row="1" Background="#f0f0f0" BorderBrush="#dfdfdf" BorderThickness="0,1,0,0">
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Style="{DynamicResource Style.ButtonStandard}"
                        Width="100"
                        IsCancel="True"
                        IsDefault="True"
                        Content="{x:Static resource:Strings.DialogButton_OK}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
