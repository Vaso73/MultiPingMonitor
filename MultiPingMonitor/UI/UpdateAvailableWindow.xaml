<Window x:Class="MultiPingMonitor.UI.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MultiPingMonitor"
        UseLayoutRounding="True"
        WindowStyle="None"
        Width="620"
        Height="460"
        MinWidth="600"
        MinHeight="440"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme.Background}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
        <DockPanel Background="{DynamicResource Theme.Background}">
            <Grid DockPanel.Dock="Top"
                  Height="32"
                  Background="{DynamicResource Theme.Surface}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Style="{DynamicResource Style.TitleBar.Title}"
                           Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />

                <Button Grid.Column="1"
                        Click="CloseButton_Click"
                        Style="{DynamicResource Style.TitleBarCloseButton}"
                        AutomationProperties.Name="Close"
                        ToolTip="Close"
                        ToolTipService.InitialShowDelay="1000">
                    <Path Width="46"
                          Height="32"
                          Data="M 18,11 27,20 M 18,20 27,11"
                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1" />
                </Button>
            </Grid>

            <Border DockPanel.Dock="Top"
                    Style="{DynamicResource Style.TitleBarSeparator}" />

            <Border DockPanel.Dock="Bottom"
                    Style="{DynamicResource Style.FooterPanel}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10">
                    <Button x:Name="LaterButton"
                            Style="{DynamicResource Style.ButtonStandard}"
                            Width="120"
                            IsCancel="True"
                            Click="LaterButton_Click" />
                    <Button x:Name="UpdateButton"
                            Style="{DynamicResource Style.ButtonStandard}"
                            Width="140"
                            Margin="8,0,0,0"
                            IsDefault="True"
                            Click="UpdateButton_Click" />
                </StackPanel>
            </Border>

            <Grid Margin="24,20,24,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="{DynamicResource icon.info-circle}"
                           Width="40"
                           Height="40"
                           Margin="0,0,16,0"
                           VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="HeaderText"
                                   Foreground="{DynamicResource Theme.Text.Primary}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SubHeaderText"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource Theme.Text.Secondary}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,20,0,0"
                        Padding="14"
                        Background="{DynamicResource Theme.Surface}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="CurrentVersionLabel"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   Foreground="{DynamicResource Theme.Text.Secondary}"
                                   Margin="0,0,8,8" />
                        <TextBlock x:Name="CurrentVersionText"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Foreground="{DynamicResource Theme.Text.Primary}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,28,8" />
                        <TextBlock x:Name="LatestVersionLabel"
                                   Grid.Row="0"
                                   Grid.Column="2"
                                   Foreground="{DynamicResource Theme.Text.Secondary}"
                                   Margin="0,0,8,8" />
                        <TextBlock x:Name="LatestVersionText"
                                   Grid.Row="0"
                                   Grid.Column="3"
                                   Foreground="{DynamicResource Theme.Text.Primary}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <TextBlock x:Name="ChannelLabel"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   Foreground="{DynamicResource Theme.Text.Secondary}"
                                   Margin="0,0,8,0" />
                        <TextBlock x:Name="ChannelText"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Foreground="{DynamicResource Theme.Text.Primary}"
                                   Margin="0,0,28,0" />
                        <TextBlock x:Name="SizeLabel"
                                   Grid.Row="1"
                                   Grid.Column="2"
                                   Foreground="{DynamicResource Theme.Text.Secondary}"
                                   Margin="0,0,8,0" />
                        <TextBlock x:Name="SizeText"
                                   Grid.Row="1"
                                   Grid.Column="3"
                                   Foreground="{DynamicResource Theme.Text.Primary}" />
                    </Grid>
                </Border>

                <TextBlock x:Name="DetailsLabelText"
                           Grid.Row="2"
                           Margin="0,16,0,6"
                           Foreground="{DynamicResource Theme.Accent}"
                           FontSize="13"
                           FontWeight="SemiBold" />

                <Border Grid.Row="3"
                        MinHeight="86"
                        Background="{DynamicResource Theme.Surface}"
                        BorderBrush="{DynamicResource Theme.Border}"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="12"
                                  CanContentScroll="False">
                        <TextBlock x:Name="DetailsText"
                                   Foreground="{DynamicResource Theme.Text.Primary}"
                                   TextWrapping="Wrap"
                                   FontSize="13" />
                    </ScrollViewer>
                </Border>

                <ProgressBar x:Name="InstallProgress"
                             Grid.Row="4"
                             Margin="0,16,0,0"
                             Height="5"
                             IsIndeterminate="True"
                             Visibility="Collapsed" />

                <TextBlock x:Name="StatusText"
                           Grid.Row="5"
                           Margin="0,12,0,0"
                           Foreground="{DynamicResource Theme.Text.Secondary}"
                           FontSize="13"
                           TextWrapping="Wrap" />
            </Grid>
        </DockPanel>
    </Border>
</Window>
