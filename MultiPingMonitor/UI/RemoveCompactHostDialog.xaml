<Window x:Class="MultiPingMonitor.UI.RemoveCompactHostDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="{x:Static resource:Strings.Compact_RemoveHost}"
        UseLayoutRounding="True"
        WindowStyle="None"
        Height="Auto" SizeToContent="Height"
        Width="380" MinWidth="280"
        Background="{DynamicResource Theme.Background}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="16" Height="16" Margin="8,0,4,0"
                   Source="{StaticResource icon.compact-view}" />
            <TextBlock Grid.Column="1" Style="{DynamicResource Style.TitleBar.Title}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button Grid.Column="2" Click="OnCloseButtonClick"
                    Style="{DynamicResource Style.TitleBarCloseButton}" AutomationProperties.Name="Close"
                    ToolTip="Close" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Style="{DynamicResource Style.TitleBarSeparator}" />

    <StackPanel Margin="12">
        <!-- Prompt label -->
        <TextBlock Foreground="{DynamicResource Theme.Text.Primary}"
                   Text="{x:Static resource:Strings.Compact_RemoveHost_SelectHost}"
                   Margin="0,0,0,6"/>

        <!-- Host list -->
        <ListBox x:Name="HostListBox"
                 MaxHeight="220"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 BorderBrush="{DynamicResource Theme.Border}"
                 BorderThickness="1"
                 Background="{DynamicResource Theme.Background}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="6,4"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="{DynamicResource Theme.Text.Primary}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Target}"
                                   Foreground="{DynamicResource Theme.Text.Secondary}"
                                   FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Alias}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- No hosts message (shown when list is empty) -->
        <TextBlock x:Name="NoHostsText"
                   Text="{x:Static resource:Strings.Compact_RemoveHost_NoHosts}"
                   Foreground="{DynamicResource Theme.Text.Secondary}"
                   FontStyle="Italic"
                   Visibility="Collapsed"
                   Margin="0,4,0,0"/>

        <!-- Close Live Ping checkbox -->
        <CheckBox x:Name="CloseLivePingCheckBox"
                  Content="{x:Static resource:Strings.Compact_RemoveHost_CloseLivePing}"
                  Foreground="{DynamicResource Theme.Text.Primary}"
                  IsChecked="False"
                  Margin="0,12,0,0"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="RemoveButton"
                    Style="{DynamicResource Style.ButtonStandard}"
                    Content="{x:Static resource:Strings.DialogButton_Remove}"
                    Width="85" Click="Remove_Click" IsDefault="True"/>
            <Button Style="{DynamicResource Style.ButtonStandard}"
                    Content="{x:Static resource:Strings.DialogButton_Cancel}"
                    Width="85" Margin="9,0,0,0" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
    </DockPanel>
    </Border>
</Window>
