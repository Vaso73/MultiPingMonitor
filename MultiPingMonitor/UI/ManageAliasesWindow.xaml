<Window x:Class="MultiPingMonitor.UI.ManageAliasesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="{x:Static resource:Strings.ManageAliases_WindowTitle}"
        UseLayoutRounding="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Height="475"
        Width="460"
        MinHeight="250"
        MinWidth="360"
        Background="{DynamicResource Theme.Background}"
        ResizeMode="CanResize"
        PreviewKeyDown="Window_PreviewKeyDown">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="16" Height="16" Margin="8,0,4,0"
                   Source="{StaticResource icon.alias}" />
            <TextBlock Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13"
                       Foreground="{DynamicResource Theme.Text.Primary}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button Grid.Column="2" Click="OnCloseButtonClick"
                    Style="{DynamicResource Style.TitleBarCloseButton}" AutomationProperties.Name="Close"
                    ToolTip="Close" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Theme.Border}" />

    <Grid Margin="9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header section -->
        <StackPanel Orientation="Horizontal">
            <Image Source="{StaticResource icon.alias}" VerticalAlignment="Center" Width="20" Height="20" Margin="0,0,8,0"/>
            <TextBlock Grid.Row="0"
                       Text="{x:Static resource:Strings.ManageAliases_Header}"
                       Style="{StaticResource ResourceKey=OptionHeaderTextStyle}"/>
        </StackPanel>
        
        <!-- Aliases DataGrid -->
        <DataGrid x:Name="Aliases"
                  Grid.Row="1"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Path=Value}" Header="{x:Static resource:Strings.ManageAliases_Alias}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource= {RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Padding" Value="7,2,10,2"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding Path=Key}" Header="{x:Static resource:Strings.ManageAliases_Host}" Width=".8*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource= {RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Padding" Value="7,2,10,2"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Accent}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Buttons section -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,9,0,0">
            <Button Click="New_Click"
                    Width="85"
                    Style="{StaticResource ButtonStandardStyle}"
                    Content="_New"/>
            <Button Click="Edit_Click"
                    Margin="15,0"
                    Width="85"
                    Style="{StaticResource ButtonStandardStyle}"
                    IsEnabled="{Binding ElementName=Aliases, Path=SelectedItems.Count}"
                    Content="_Edit"/>
            <Button Click="Remove_Click"
                    Width="85"
                    Style="{StaticResource ButtonStandardStyle}"
                    IsEnabled="{Binding ElementName=Aliases, Path=SelectedItems.Count}"
                    Content="_Remove"/>
        </StackPanel>
    </Grid>
    </DockPanel>
    </Border>
</Window>
