<Window x:Class="MultiPingMonitor.UI.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="MultiPingMonitor"
        UseLayoutRounding="True"
        WindowStyle="None"
        Height="Auto"
        Width="480"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme.Background}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{DynamicResource Style.TitleBar.Title}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button Grid.Column="1" Click="OnCloseButtonClick"
                    Style="{DynamicResource Style.TitleBarCloseButton}" AutomationProperties.Name="Close"
                    ToolTip="Close" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Style="{DynamicResource Style.TitleBarSeparator}" />

        <!-- Icon and text -->
        <Grid DockPanel.Dock="Top" Margin="20,16,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image x:Name="MessageImage"
                   VerticalAlignment="Top"
                   Width="32"
                   Height="32"/>
            <DockPanel Grid.Column="1" Margin="15,4,0,0">
                <TextBlock x:Name="MessageHeader"
                           DockPanel.Dock="Top"
                           Foreground="{DynamicResource Theme.Text.Primary}"
                           FontSize="15"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="MessageBody"
                           DockPanel.Dock="Top"
                           FontSize="13"
                           Margin="0,12,0,0"
                           Foreground="{DynamicResource Theme.Text.Primary}"
                           TextWrapping="Wrap"/>
            </DockPanel>
        </Grid>

        <!-- Buttons -->
        <Border DockPanel.Dock="Bottom" Style="{DynamicResource Style.FooterPanel}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="10">
                <Button x:Name="OK"
                        Style="{DynamicResource Style.ButtonStandard}"
                        Click="OK_Click"
                        Width="100"
                        IsDefault="True"
                        IsCancel="{Binding Visibility, ElementName=Cancel, Converter={StaticResource InverseHiddenToBoolConverter}}"
                        Content="{x:Static resource:Strings.DialogButton_OK}" />
                <Button x:Name="Cancel"
                        Style="{DynamicResource Style.ButtonStandard}"
                        Margin="8,0,0,0"
                        Width="100"
                        IsCancel="True"
                        Content="{x:Static resource:Strings.DialogButton_Cancel}" />
            </StackPanel>
        </Border>

    </DockPanel>
    </Border>
</Window>
