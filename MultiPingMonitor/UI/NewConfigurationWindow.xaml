<Window x:Class="MultiPingMonitor.UI.NewConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        mc:Ignorable="d"
        Title="{x:Static resource:Strings.NewConfiguration_WindowTitle}"
        Height="Auto"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{DynamicResource Theme.Background}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
    <DockPanel Background="{DynamicResource Theme.Background}">

        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="16" Height="16" Margin="8,0,4,0"
                   Source="{StaticResource icon.file-code}" />
            <TextBlock Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13"
                       Foreground="{DynamicResource Theme.Text.Primary}"
                       Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Button Grid.Column="2" Click="OnCloseButtonClick"
                    Style="{DynamicResource Style.TitleBarCloseButton}" AutomationProperties.Name="Close"
                    ToolTip="Close" ToolTipService.InitialShowDelay="1000">
                <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" StrokeThickness="1" />
            </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Theme.Border}" />

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,20,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Icon -->
            <Image Source="{StaticResource icon.file-code}"
                   Margin="0,3,0,0"
                   VerticalAlignment="Top"
                   Opacity="0.8"
                   Width="32"
                   Height="32"/>
            <!-- Main content -->
            <DockPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock DockPanel.Dock="Top"
                           FontSize="14"
                           Foreground="{DynamicResource Theme.Text.Primary}"
                           TextWrapping="Wrap"
                           Text="{x:Static resource:Strings.NewConfiguration_Description}"/>
                <TextBlock DockPanel.Dock="Top"
                           FontSize="14"
                           Foreground="{DynamicResource Theme.Text.Primary}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,1"
                           Text="{x:Static resource:Strings.NewConfiguration_PathDescription}"/>
                <!-- File path -->
                <TextBlock x:Name="FilePath"
                           DockPanel.Dock="Top"
                           FontSize="12"
                           Foreground="{DynamicResource Theme.Accent}"
                           TextWrapping="Wrap"
                           d:Text="C:\Program Files\MultiPingMonitor\MultiPingMonitor.xml"/>
            </DockPanel>
        </Grid>
        
        <!-- Buttons -->
        <Border Grid.Row="1" Background="{DynamicResource Theme.Surface}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0">
            <DockPanel Margin="10">
                <!-- Buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ButtonStandardStyle}"
                            Click="Save_Click"
                            Width="100"
                            IsDefault="True"
                            Content="{x:Static resource:Strings.DialogButton_Save}" />
                    <Button Style="{StaticResource ButtonStandardStyle}"
                            Margin="8,0,0,0"
                            Width="100"
                            IsCancel="True"
                            Content="{x:Static resource:Strings.DialogButton_Cancel}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
    </DockPanel>
    </Border>
</Window>
