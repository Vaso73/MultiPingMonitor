<Window x:Class="MultiPingMonitor.UI.NewConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MultiPingMonitor.UI"
        mc:Ignorable="d"
        Title="New Configuration"
        Height="Auto"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,20,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Icon -->
            <Image Source="{StaticResource icon.file-code}"
                   Margin="0,3,0,0"
                   VerticalAlignment="Top"
                   Opacity="0.8"
                   Width="32"
                   Height="32"/>
            <!-- Main content -->
            <DockPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock DockPanel.Dock="Top"
                           FontSize="14"
                           Foreground="{DynamicResource Theme.Text.Primary}"
                           TextWrapping="Wrap"
                           Text="To save your settings, a new configuration file is needed."/>
                <TextBlock DockPanel.Dock="Top"
                           FontSize="14"
                           Foreground="{DynamicResource Theme.Text.Primary}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,1"
                           Text="The configuration file will be created alongside the application:"/>
                <!-- File path -->
                <TextBlock x:Name="FilePath"
                           DockPanel.Dock="Top"
                           FontSize="12"
                           Foreground="{DynamicResource Theme.Accent}"
                           TextWrapping="Wrap"
                           d:Text="C:\Program Files\MultiPingMonitor\MultiPingMonitor.xml"/>
            </DockPanel>
        </Grid>
        
        <!-- Buttons -->
        <Border Grid.Row="1" Background="{DynamicResource Theme.SurfaceAlt}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0">
            <DockPanel Margin="10">
                <!-- Buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ButtonStandardStyle}"
                            Click="Save_Click"
                            Width="100"
                            IsDefault="True"
                            Content="Save" />
                    <Button Style="{StaticResource ButtonStandardStyle}"
                            Margin="8,0,0,0"
                            Width="100"
                            IsCancel="True"
                            Content="Cancel" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
