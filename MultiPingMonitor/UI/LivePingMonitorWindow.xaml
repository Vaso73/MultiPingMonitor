<Window x:Class="MultiPingMonitor.UI.LivePingMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:classes="clr-namespace:MultiPingMonitor.Classes"
        Title="Live Ping Monitor"
        UseLayoutRounding="True"
        Height="480"
        Width="500"
        MinHeight="280"
        MinWidth="320"
        WindowStyle="None"
        Background="{DynamicResource Theme.Background}"
        Closed="Window_Closed"
        PreviewKeyDown="Window_PreviewKeyDown"
        StateChanged="Window_StateChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource WindowMainPanelStyle}">
        <DockPanel Background="{DynamicResource Theme.Background}">

            <!-- Title bar -->
            <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Window icon -->
                <Image Grid.Column="0" Source="/MultiPingMonitor.ico" Width="16" Height="16" Margin="8,0,4,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <!-- Title text -->
                <TextBlock Grid.Column="1" Text="Live Ping Monitor"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource Theme.Text.Secondary}" Margin="4,0,0,0" />
                <!-- Minimize -->
                <Button Grid.Column="2" Style="{StaticResource TitleBarButtonStyle}"
                        Width="46" Click="MinimizeButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="10" Height="1" Data="M0,0 H10" Stretch="None"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" />
                </Button>
                <!-- Maximize/Restore -->
                <Button Grid.Column="3" Style="{StaticResource TitleBarButtonStyle}"
                        Width="46" Click="MaximizeRestoreButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="10" Height="10" Data="M0,0 H10 V10 H0 Z" Stretch="None"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" />
                </Button>
                <!-- Close -->
                <Button Grid.Column="4" Style="{StaticResource TitleBarCloseButtonStyle}"
                        Width="46" Click="CloseButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="10" Height="10" Data="M0,0 L10,10 M0,10 L10,0" Stretch="None"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" />
                </Button>
            </Grid>

            <!-- Header area -->
            <Border x:Name="HeaderBorder" DockPanel.Dock="Top" Background="{DynamicResource Theme.Surface}" Padding="12,8"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                        <!-- Display name: alias or hostname -->
                        <TextBlock x:Name="HeaderDisplayName" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.Text.Primary}" TextTrimming="CharacterEllipsis" />
                        <!-- Secondary: hostname/IP if alias is shown -->
                        <TextBlock x:Name="HeaderTarget" FontSize="12"
                                   Foreground="{DynamicResource Theme.Text.Secondary}" TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0">
                        <!-- Status indicator — enlarged for DOWN emphasis -->
                        <TextBlock x:Name="HeaderStatus" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Right" />
                        <!-- Latest latency -->
                        <TextBlock x:Name="HeaderLatency" FontSize="12" FontFamily="Consolas"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource Theme.Text.Secondary}" Margin="0,2,0,0" />
                    </StackPanel>
                    <!-- Toolbar row: Always on top + Copy actions -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox x:Name="AlwaysOnTopCheckBox" VerticalAlignment="Center"
                                  Foreground="{DynamicResource Theme.Text.Secondary}" FontSize="11"
                                  Checked="AlwaysOnTopCheckBox_Changed" Unchecked="AlwaysOnTopCheckBox_Changed" />
                        <Button x:Name="CopyTargetButton" Click="CopyTargetButton_Click"
                                Padding="6,2" Margin="12,0,0,0" FontSize="11"
                                Background="{DynamicResource Theme.SurfaceAlt}"
                                Foreground="{DynamicResource Theme.Text.Secondary}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                WindowChrome.IsHitTestVisibleInChrome="True" Cursor="Hand" />
                        <Button x:Name="CopyAddressButton" Click="CopyAddressButton_Click"
                                Padding="6,2" Margin="4,0,0,0" FontSize="11"
                                Background="{DynamicResource Theme.SurfaceAlt}"
                                Foreground="{DynamicResource Theme.Text.Secondary}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                WindowChrome.IsHitTestVisibleInChrome="True" Cursor="Hand" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Paused banner -->
            <Border x:Name="PausedBanner" DockPanel.Dock="Top" Visibility="Collapsed"
                    Background="{DynamicResource Theme.SurfaceAlt}" Padding="8,4"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="PausedBannerText" Text="⏸  Paused" FontSize="11" FontStyle="Italic"
                           Foreground="{DynamicResource Theme.Warning}" HorizontalAlignment="Center" />
            </Border>

            <!-- Footer: stats and buttons -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource Theme.Surface}" Padding="8,6"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <!-- Buttons on the right -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="StopResumeButton" Content="Stop" Click="StopResumeButton_Click"
                                Padding="10,4" Margin="4,0,0,0" FontSize="12"
                                Background="{DynamicResource Theme.SurfaceAlt}"
                                Foreground="{DynamicResource Theme.Text.Primary}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                WindowChrome.IsHitTestVisibleInChrome="True" Cursor="Hand" />
                        <Button x:Name="ClearButton" Content="Clear" Click="ClearButton_Click"
                                Padding="10,4" Margin="4,0,0,0" FontSize="12"
                                Background="{DynamicResource Theme.SurfaceAlt}"
                                Foreground="{DynamicResource Theme.Text.Primary}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                WindowChrome.IsHitTestVisibleInChrome="True" Cursor="Hand" />
                        <Button x:Name="CloseFooterButton" Content="Close" Click="CloseButton_Click"
                                Padding="10,4" Margin="4,0,0,0" FontSize="12"
                                Background="{DynamicResource Theme.SurfaceAlt}"
                                Foreground="{DynamicResource Theme.Text.Primary}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                WindowChrome.IsHitTestVisibleInChrome="True" Cursor="Hand" />
                    </StackPanel>
                    <!-- Statistics on the left -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Sent: " FontSize="12" Foreground="{DynamicResource Theme.Text.Secondary}" />
                        <TextBlock x:Name="StatsSent" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.Info}" Margin="0,0,10,0" />
                        <TextBlock Text="Received: " FontSize="12" Foreground="{DynamicResource Theme.Text.Secondary}" />
                        <TextBlock x:Name="StatsReceived" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.Success}" Margin="0,0,10,0" />
                        <TextBlock Text="Lost: " FontSize="12" Foreground="{DynamicResource Theme.Text.Secondary}" />
                        <TextBlock x:Name="StatsLost" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.Danger}" Margin="0,0,10,0" />
                        <TextBlock x:Name="StatsLossPercent" FontSize="12"
                                   Foreground="{DynamicResource Theme.Text.Secondary}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main content: scrollable rolling log with color-coded lines -->
            <ListBox x:Name="LogListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="12"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionMode="Extended"
                     IsTabStop="False"
                     Margin="0">
                <ListBox.Resources>
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ScrollBarStyle.Dark}"/>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type classes:LogEntry}">
                        <TextBlock Text="{Binding Text}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Padding" Value="6,1" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static classes:LogEntryKind.Success}">
                                <Setter Property="Foreground" Value="{DynamicResource Theme.Success}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static classes:LogEntryKind.Failure}">
                                <Setter Property="Foreground" Value="{DynamicResource Theme.Danger}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static classes:LogEntryKind.Warning}">
                                <Setter Property="Foreground" Value="{DynamicResource Theme.Warning}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static classes:LogEntryKind.Info}">
                                <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

        </DockPanel>
    </Border>
</Window>
