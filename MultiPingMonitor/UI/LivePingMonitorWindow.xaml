<Window x:Class="MultiPingMonitor.UI.LivePingMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:classes="clr-namespace:MultiPingMonitor.Classes"
        Title="Live Ping Monitor"
        UseLayoutRounding="True"
        Height="480"
        Width="500"
        MinHeight="280"
        MinWidth="320"
        WindowStyle="None"
        Background="{DynamicResource Theme.Background}"
        Closed="Window_Closed"
        PreviewKeyDown="Window_PreviewKeyDown"
        StateChanged="Window_StateChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource Style.WindowMainPanel}">
        <DockPanel Background="{DynamicResource Theme.Background}">

            <!-- Title bar -->
            <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource Theme.Surface}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Window icon -->
                <Image Grid.Column="0" Source="{StaticResource icon.vmping-logo-simple}" Width="16" Height="16" Margin="8,0,4,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <!-- Title text -->
                <TextBlock Grid.Column="1" Style="{DynamicResource Style.TitleBar.Title}"
                           Text="Live Ping Monitor" />
                <!-- Arrange menu button -->
                <Button x:Name="ArrangeMenuButton" Grid.Column="2"
                        Style="{DynamicResource Style.TitleBarButton}"
                        Width="46" Click="ArrangeMenuButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="Arrange">
                    <!-- Grid/arrange icon (four squares) -->
                    <Path Width="12" Height="12" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1"
                          Data="M0,0 H5 V5 H0 Z M7,0 H12 V5 H7 Z M0,7 H5 V12 H0 Z M7,7 H12 V12 H7 Z" />
                </Button>
                <!-- Minimize -->
                <Button Grid.Column="3" Style="{DynamicResource Style.TitleBarButton}"
                        Width="46" Click="MinimizeButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="46" Height="32" Data="M 18,15 H 28" Stretch="None"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" />
                </Button>
                <!-- Maximize/Restore -->
                <Button Grid.Column="4" Style="{DynamicResource Style.TitleBarButton}"
                        Width="46" Click="MaximizeRestoreButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="46" Height="32" Data="M 18.5,10.5 H 27.5 V 19.5 H 18.5 Z" Stretch="None"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" />
                </Button>
                <!-- Close -->
                <Button Grid.Column="5" Style="{DynamicResource Style.TitleBarCloseButton}"
                        Width="46" Click="CloseButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="46" Height="32" Data="M 18,11 27,20 M 18,20 27,11" Stretch="None"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" />
                </Button>
            </Grid>

            <!-- Header area -->
            <Border x:Name="HeaderBorder" DockPanel.Dock="Top" Style="{DynamicResource Style.HeaderPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Left: display name + target -->
                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderDisplayName" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.Text.Primary}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="HeaderTarget" FontSize="11"
                                   Foreground="{DynamicResource Theme.Text.Secondary}" TextTrimming="CharacterEllipsis"
                                   Margin="0,1,0,0" Opacity="{DynamicResource Style.Opacity.Secondary}" />
                    </StackPanel>
                    <!-- Right: status + latency badge -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{DynamicResource Style.LivePingStatusBlock}"
                            VerticalAlignment="Center" Margin="10,0,0,0">
                        <StackPanel HorizontalAlignment="Right">
                            <TextBlock x:Name="HeaderStatus" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                            <Border Style="{DynamicResource Style.LivePingLatencyBadge}"
                                    HorizontalAlignment="Right">
                                <TextBlock x:Name="HeaderLatency" FontSize="13" FontFamily="Consolas"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource Theme.Text.Primary}" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <!-- Toolbar row: Always on top + separator + Copy actions -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
                        <ToggleButton x:Name="AlwaysOnTopCheckBox"
                                      Style="{DynamicResource Style.HeaderToggleButton}"
                                      VerticalAlignment="Center"
                                      Checked="AlwaysOnTopCheckBox_Changed"
                                      Unchecked="AlwaysOnTopCheckBox_Changed">
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="PinIcon" Width="10" Height="12" Stretch="Uniform"
                                      Fill="{DynamicResource Theme.Text.Secondary}" VerticalAlignment="Center"
                                      Data="M7,0 L9,0 9,4 12,6 12,8 8,8 8,14 7,14 7,8 3,8 3,6 7,4 Z" />
                                <TextBlock x:Name="AlwaysOnTopText" Text="Always on top" Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Theme.Text.Primary}" />
                            </StackPanel>
                        </ToggleButton>
                        <Border Style="{DynamicResource Style.LivePingToolbarSeparator}" />
                        <Button x:Name="CopyTargetButton" Click="CopyTargetButton_Click"
                                Style="{DynamicResource Style.LivePingActionButton}"
                                Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="10" Height="11" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{DynamicResource Theme.Text.Secondary}"
                                      Data="M4,0 L4,1 1,1 1,11 9,11 9,4 10,4 10,12 0,12 0,0 Z M3,0 L3,8 11,8 11,0 Z M4,1 L10,1 10,7 4,7 Z" />
                                <TextBlock x:Name="CopyTargetText" Text="Copy Target" Margin="4,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CopyAddressButton" Click="CopyAddressButton_Click"
                                Style="{DynamicResource Style.LivePingActionButton}"
                                Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="11" Height="10" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{DynamicResource Theme.Text.Secondary}"
                                      Data="M0,0 L12,0 12,9 7,9 7,11 9,11 9,12 3,12 3,11 5,11 5,9 0,9 Z M1,1 L1,8 11,8 11,1 Z M4,3 L2,5 4,7 5,6 3.5,5 5,4 Z M8,3 L7,4 8.5,5 7,6 8,7 10,5 Z" />
                                <TextBlock x:Name="CopyAddressText" Text="Copy Address" Margin="4,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Paused banner -->
            <Border x:Name="PausedBanner" DockPanel.Dock="Top" Visibility="Collapsed"
                    Background="{DynamicResource Theme.SurfaceAlt}" Padding="8,4"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="PausedBannerText" Text="⏸  Paused" FontSize="11" FontStyle="Italic"
                           Foreground="{DynamicResource Theme.Warning}" HorizontalAlignment="Center" />
            </Border>

            <!-- Footer: stats and buttons -->
            <Border DockPanel.Dock="Bottom" Style="{DynamicResource Style.FooterPanel}">
                <DockPanel>
                    <!-- Buttons on the right -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="StopResumeButton" Content="Stop" Click="StopResumeButton_Click"
                                Style="{DynamicResource Style.LivePingFooterButton}"
                                Margin="4,0,0,0" />
                        <Button x:Name="ClearButton" Content="Clear" Click="ClearButton_Click"
                                Style="{DynamicResource Style.LivePingFooterButton}"
                                Margin="4,0,0,0" />
                        <Button x:Name="CloseFooterButton" Content="Close" Click="CloseButton_Click"
                                Style="{DynamicResource Style.LivePingFooterButton}"
                                Margin="4,0,0,0" />
                    </StackPanel>
                    <!-- Statistics: segmented metric blocks -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{DynamicResource Style.LivePingStatSegment}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Sent" FontSize="11"
                                           Foreground="{DynamicResource Theme.Text.Secondary}"
                                           VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock x:Name="StatsSent" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource Theme.Info}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource Style.LivePingStatSegment}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Recv" FontSize="11"
                                           Foreground="{DynamicResource Theme.Text.Secondary}"
                                           VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock x:Name="StatsReceived" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource Theme.Success}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource Style.LivePingStatSegment}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Lost" FontSize="11"
                                           Foreground="{DynamicResource Theme.Text.Secondary}"
                                           VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock x:Name="StatsLost" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource Theme.Danger}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="StatsLossPercent" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.Text.Secondary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main content: scrollable rolling log with color-coded lines -->
            <ListBox x:Name="LogListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="12"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionMode="Extended"
                     IsTabStop="False"
                     Margin="0"
                     Padding="0,2">
                <ListBox.Resources>
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ScrollBarStyle.Dark}"/>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type classes:LogEntry}">
                        <TextBlock Text="{Binding Text}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border x:Name="RowBorder"
                                            Style="{DynamicResource Style.LivePingLogRow}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceAlt}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static classes:LogEntryKind.Success}">
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Success}" />
                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource Theme.Success}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static classes:LogEntryKind.Failure}">
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Danger}" />
                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource Theme.Danger}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static classes:LogEntryKind.Warning}">
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Warning}" />
                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource Theme.Warning}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static classes:LogEntryKind.Info}">
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary}" />
                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="Transparent" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

        </DockPanel>
    </Border>
</Window>
