<Window x:Class="MultiPingMonitor.UI.AddToSetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resource="clr-namespace:MultiPingMonitor.Properties"
        Title="{x:Static resource:Strings.LivePing_AddToSet_Title}"
        UseLayoutRounding="True"
        Height="Auto"
        Width="400"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme.Background}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        ShowInTaskbar="False">

    <DockPanel>
        <!-- Content -->
        <Border DockPanel.Dock="Top" Padding="20,16,20,12">
            <StackPanel>
                <!-- Target display -->
                <TextBlock Text="{Binding TargetDisplayText}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Theme.Text.Primary}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,12"/>

                <!-- Destination type -->
                <TextBlock Text="{x:Static resource:Strings.LivePing_AddToSet_DestType}"
                           FontSize="12" Foreground="{DynamicResource Theme.Text.Secondary}"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RadioNormal" GroupName="DestType"
                                 Content="{x:Static resource:Strings.LivePing_AddToSet_Normal}"
                                 FontSize="12" Foreground="{DynamicResource Theme.Text.Primary}"
                                 IsChecked="True"
                                 Checked="DestType_Changed"
                                 Margin="0,0,16,0" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="RadioCompact" GroupName="DestType"
                                 Content="Compact" FontSize="12"
                                 Foreground="{DynamicResource Theme.Text.Primary}"
                                 Checked="DestType_Changed"
                                 VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Compact set selection (visible only when Compact is chosen) -->
                <StackPanel x:Name="CompactSetPanel" Visibility="Collapsed" Margin="0,0,0,12">
                    <TextBlock Text="{x:Static resource:Strings.LivePing_AddToSet_Compact}"
                               FontSize="12" Foreground="{DynamicResource Theme.Text.Secondary}"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="CompactSetCombo"
                              FontSize="12"
                              Background="{DynamicResource Theme.Surface}"
                              Foreground="{DynamicResource Theme.Text.Primary}"
                              BorderBrush="{DynamicResource Theme.Border}"/>
                </StackPanel>

                <!-- Alias -->
                <TextBlock Text="{x:Static resource:Strings.LivePing_AddToSet_Alias}"
                           FontSize="12" Foreground="{DynamicResource Theme.Text.Secondary}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="AliasTextBox" FontSize="12" Height="26" Padding="4,2"
                         Background="{DynamicResource Theme.Surface}"
                         Foreground="{DynamicResource Theme.Text.Primary}"
                         BorderBrush="{DynamicResource Theme.Border}"
                         CaretBrush="{DynamicResource Theme.Text.Primary}"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Style="{DynamicResource Style.FooterPanel}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8">
                <Button x:Name="OKButton"
                        Content="{x:Static resource:Strings.DialogButton_OK}"
                        Style="{DynamicResource Style.ButtonStandard}"
                        Width="88" IsDefault="True"
                        Click="OK_Click"/>
                <Button Content="{x:Static resource:Strings.DialogButton_Cancel}"
                        Style="{DynamicResource Style.ButtonStandard}"
                        Width="88" IsCancel="True"
                        Margin="8,0,0,0"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
