<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme colors (macOS-inspired) -->

    <!-- Window / panel backgrounds -->
    <SolidColorBrush x:Key="Theme.Window.Background"         Color="#1C1C1E"/>
    <SolidColorBrush x:Key="Theme.Panel.Background"          Color="#2C2C2E"/>
    <SolidColorBrush x:Key="Theme.Panel.Secondary.Background" Color="#3A3A3C"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Theme.Text.Primary"              Color="#F5F5F7"/>
    <SolidColorBrush x:Key="Theme.Text.Secondary"            Color="#AEAEB2"/>
    <SolidColorBrush x:Key="Theme.Text.Disabled"             Color="#636366"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Theme.Accent"                    Color="#0A84FF"/>
    <SolidColorBrush x:Key="Theme.Accent.Hover"              Color="#409CFF"/>
    <SolidColorBrush x:Key="Theme.Accent.Foreground"         Color="#FFFFFF"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="Theme.Border"                    Color="#3A3A3C"/>
    <SolidColorBrush x:Key="Theme.Border.Focus"              Color="#0A84FF"/>

    <!-- Control backgrounds -->
    <SolidColorBrush x:Key="Theme.Control.Background"        Color="#2C2C2E"/>
    <SolidColorBrush x:Key="Theme.Control.Background.Hover"  Color="#3A3A3C"/>
    <SolidColorBrush x:Key="Theme.Control.Background.Pressed" Color="#48484A"/>

    <!-- Toolbar -->
    <SolidColorBrush x:Key="Theme.Toolbar.Background"        Color="#2C2C2E"/>

    <!-- Separator -->
    <SolidColorBrush x:Key="Theme.Separator"                 Color="#3A3A3C"/>

</ResourceDictionary>
