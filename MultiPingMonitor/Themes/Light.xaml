<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme colors (macOS-inspired) -->

    <!-- Window / panel backgrounds -->
    <SolidColorBrush x:Key="Theme.Window.Background"         Color="#F5F5F7"/>
    <SolidColorBrush x:Key="Theme.Panel.Background"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.Panel.Secondary.Background" Color="#EBEBED"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Theme.Text.Primary"              Color="#1D1D1F"/>
    <SolidColorBrush x:Key="Theme.Text.Secondary"            Color="#6E6E73"/>
    <SolidColorBrush x:Key="Theme.Text.Disabled"             Color="#AEAEB2"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Theme.Accent"                    Color="#0071E3"/>
    <SolidColorBrush x:Key="Theme.Accent.Hover"              Color="#0077ED"/>
    <SolidColorBrush x:Key="Theme.Accent.Foreground"         Color="#FFFFFF"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="Theme.Border"                    Color="#D1D1D6"/>
    <SolidColorBrush x:Key="Theme.Border.Focus"              Color="#0071E3"/>

    <!-- Control backgrounds -->
    <SolidColorBrush x:Key="Theme.Control.Background"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.Control.Background.Hover"  Color="#F0F0F5"/>
    <SolidColorBrush x:Key="Theme.Control.Background.Pressed" Color="#E5E5EA"/>

    <!-- Toolbar -->
    <SolidColorBrush x:Key="Theme.Toolbar.Background"        Color="#E8E8ED"/>

    <!-- Separator -->
    <SolidColorBrush x:Key="Theme.Separator"                 Color="#D1D1D6"/>

</ResourceDictionary>
