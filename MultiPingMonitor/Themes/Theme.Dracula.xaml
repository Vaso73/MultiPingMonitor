<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Theme.Background.Color">#FF282A36</Color>
    <Color x:Key="Theme.Surface.Color">#FF343746</Color>
    <Color x:Key="Theme.SurfaceAlt.Color">#FF44475A</Color>
    <Color x:Key="Theme.Border.Color">#FF6272A4</Color>
    <Color x:Key="Theme.Text.Primary.Color">#FFF8F8F2</Color>
    <Color x:Key="Theme.Text.Secondary.Color">#FF6272A4</Color>
    <Color x:Key="Theme.Accent.Color">#FFBD93F9</Color>
    <Color x:Key="Theme.AccentHover.Color">#FFFF79C6</Color>
    <Color x:Key="Theme.AccentForeground.Color">#FF282A36</Color>
    <Color x:Key="Theme.Success.Color">#FF50FA7B</Color>
    <Color x:Key="Theme.Danger.Color">#FFFF5555</Color>
    <Color x:Key="Theme.Warning.Color">#FFFFB86C</Color>
    <Color x:Key="Theme.Info.Color">#FF8BE9FD</Color>
    <SolidColorBrush x:Key="Theme.Background" Color="{StaticResource Theme.Background.Color}"/>
    <SolidColorBrush x:Key="Theme.Surface" Color="{StaticResource Theme.Surface.Color}"/>
    <SolidColorBrush x:Key="Theme.SurfaceAlt" Color="{StaticResource Theme.SurfaceAlt.Color}"/>
    <SolidColorBrush x:Key="Theme.Border" Color="{StaticResource Theme.Border.Color}"/>
    <SolidColorBrush x:Key="Theme.Text.Primary" Color="{StaticResource Theme.Text.Primary.Color}"/>
    <SolidColorBrush x:Key="Theme.Text.Secondary" Color="{StaticResource Theme.Text.Secondary.Color}"/>
    <SolidColorBrush x:Key="Theme.Accent" Color="{StaticResource Theme.Accent.Color}"/>
    <SolidColorBrush x:Key="Theme.AccentHover" Color="{StaticResource Theme.AccentHover.Color}"/>
    <SolidColorBrush x:Key="Theme.AccentForeground" Color="{StaticResource Theme.AccentForeground.Color}"/>
    <SolidColorBrush x:Key="Theme.Success" Color="{StaticResource Theme.Success.Color}"/>
    <SolidColorBrush x:Key="Theme.Danger" Color="{StaticResource Theme.Danger.Color}"/>
    <SolidColorBrush x:Key="Theme.Warning" Color="{StaticResource Theme.Warning.Color}"/>
    <SolidColorBrush x:Key="Theme.Info" Color="{StaticResource Theme.Info.Color}"/>
</ResourceDictionary>
