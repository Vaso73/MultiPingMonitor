<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile: Folder publish (win-x64), self-contained.
  Use this as a fallback if the single-file build causes issues.
  Usage:
    dotnet publish -p:PublishProfile=FolderPublish
  Output: bin\Release\net8.0-windows\win-x64\publish-folder\
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Release\net8.0-windows\win-x64\publish-folder\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
